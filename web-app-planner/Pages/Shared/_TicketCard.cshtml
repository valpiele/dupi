@model Planner.Models.Ticket
@using Planner.Models

@{
    var stateBadge = Model.State switch
    {
        TicketState.Open       => "secondary",
        TicketState.InProgress => "primary",
        TicketState.Closed     => "success",
        _                      => "secondary"
    };
    var stateLabel = Model.State switch
    {
        TicketState.Open       => "Open",
        TicketState.InProgress => "In Progress",
        TicketState.Closed     => "Closed",
        _                      => ""
    };
}

<a asp-page="/Tickets/Detail" asp-route-id="@Model.Id" class="text-decoration-none">
    <div class="card mb-2 border-0 shadow-sm hover-card">
        <div class="card-body py-2 px-3">
            <div class="d-flex justify-content-between align-items-start">
                <span class="text-dark fw-medium">@Model.Title</span>
                <span class="badge bg-@stateBadge ms-2 flex-shrink-0">@stateLabel</span>
            </div>
            <div class="text-muted small mt-1">
                @Model.Author.DisplayName &middot; @Model.CreatedAt.ToString("MMM d")
            </div>
        </div>
    </div>
</a>
