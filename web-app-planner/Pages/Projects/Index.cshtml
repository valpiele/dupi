@page
@model Planner.Pages.Projects.IndexModel
@{
    ViewData["Title"] = "My Projects";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">My Projects</h2>
    <a asp-page="/Projects/Create" class="btn btn-dark">
        <i class="bi bi-plus-lg me-1"></i> New Project
    </a>
</div>

@if (!Model.Projects.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-folder2-open display-4"></i>
        <p class="mt-3">No projects yet. Create your first one.</p>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var p in Model.Projects)
        {
            <div class="col-md-4">
                <a asp-page="/Projects/Detail" asp-route-id="@p.Id" class="text-decoration-none">
                    <div class="card h-100 shadow-sm border-0 hover-card">
                        <div class="card-body">
                            <h5 class="card-title text-dark">@p.Name</h5>
                            @if (!string.IsNullOrEmpty(p.Description))
                            {
                                <p class="card-text text-muted small">@p.Description</p>
                            }
                        </div>
                        <div class="card-footer bg-transparent text-muted small d-flex justify-content-between">
                            <span><i class="bi bi-people me-1"></i>@p.Members.Count member(s)</span>
                            <span>@p.CreatedAt.ToString("MMM d, yyyy")</span>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
}
