@model dupi.Models.LoginViewModel
@{
    ViewData["Title"] = "Welcome";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>dupi</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <style>
        html, body { height: 100%; margin: 0; background: #f8f9fa; }
        body {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
        }
        .card-login {
            background: #fff;
            border: 1px solid #e5e5e5;
            border-radius: 16px;
            padding: 2.5rem 2rem;
            width: 100%;
            max-width: 380px;
            box-shadow: 0 4px 24px rgba(0,0,0,.06);
        }
        .brand {
            font-size: 2rem;
            font-weight: 700;
            letter-spacing: -1.5px;
            color: #1a1a1a;
            margin-bottom: 0.25rem;
        }
        .tagline {
            color: #888;
            font-size: 0.88rem;
            margin-bottom: 1.75rem;
        }
        .form-control {
            border-radius: 8px;
            border-color: #e0e0e0;
            font-size: 0.9rem;
            padding: 0.6rem 0.85rem;
        }
        .form-control:focus {
            border-color: #1a1a1a;
            box-shadow: 0 0 0 3px rgba(0,0,0,.06);
        }
        .btn-signin {
            background: #1a1a1a;
            color: #fff;
            border: none;
            border-radius: 8px;
            width: 100%;
            padding: 0.65rem;
            font-size: 0.9rem;
            font-weight: 500;
            transition: opacity .15s;
        }
        .btn-signin:hover { opacity: 0.85; color: #fff; }
        .divider {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            color: #bbb;
            font-size: 0.8rem;
            margin: 1.25rem 0;
        }
        .divider::before, .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #e5e5e5;
        }
        .btn-google {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            background: #fff;
            border: 1px solid #dadce0;
            border-radius: 8px;
            padding: 0.6rem;
            font-size: 0.88rem;
            font-weight: 500;
            color: #3c4043;
            text-decoration: none;
            transition: box-shadow .15s;
            width: 100%;
        }
        .btn-google:hover { box-shadow: 0 2px 8px rgba(0,0,0,.12); color: #3c4043; }
        .btn-google svg { width: 18px; height: 18px; flex-shrink: 0; }
        .register-link {
            font-size: 0.83rem;
            color: #888;
            text-align: center;
            margin-top: 1.25rem;
        }
        .register-link a { color: #1a1a1a; font-weight: 500; text-decoration: none; }
        .register-link a:hover { text-decoration: underline; }
    </style>
</head>
<body>
    <div class="card-login">
        <div class="brand">dupi</div>
        <p class="tagline">Upload, organise and share your project portfolios.</p>

        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-3" role="alert"></div>

        <form asp-controller="Account" asp-action="Login" method="post">
            <input type="hidden" asp-for="ReturnUrl" />
            <div class="mb-2">
                <input asp-for="Email" class="form-control" placeholder="Email" autocomplete="email" />
            </div>
            <div class="mb-3">
                <input asp-for="Password" class="form-control" placeholder="Password" autocomplete="current-password" />
            </div>
            <button type="submit" class="btn-signin">Sign in</button>
        </form>

        <div class="divider">or</div>

        <a href="/Account/LoginWithGoogle" class="btn-google">
            <svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
                <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
                <path fill="none" d="M0 0h48v48H0z"/>
            </svg>
            Continue with Google
        </a>

        <p class="register-link">No account? <a asp-controller="Account" asp-action="Register">Create one</a></p>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
