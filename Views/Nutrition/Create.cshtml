@{
    ViewData["Title"] = "Analyse a meal";
}

<div style="max-width:560px; margin: 0 auto;">
    <h2 class="fw-bold mb-1">Analyse a meal</h2>
    <p class="text-muted mb-4">Upload a photo, a PDF nutrition plan, or just describe what you ate.</p>

    <div id="errorBox" class="alert alert-danger d-none"></div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <form id="analyseForm" asp-action="Create" method="post" enctype="multipart/form-data">
        <div class="mb-3">
            <label class="form-label fw-medium">Title <span class="text-muted fw-normal">(optional)</span></label>
            <input type="text" name="title" class="form-control" placeholder="e.g. Monday lunch"
                   style="border-radius:8px;" />
        </div>

        <div class="mb-3">
            <label class="form-label fw-medium">Upload a photo or PDF <span class="text-muted fw-normal">(optional)</span></label>
            <input type="file" name="file" id="fileInput" class="form-control"
                   accept="image/jpeg,image/png,image/webp,application/pdf"
                   style="border-radius:8px;" />
            <div class="form-text">JPEG, PNG, WebP or PDF · max 10MB</div>

            <div id="previewBox" class="mt-2 d-none">
                <img id="imgPreview" src="#" alt="Preview"
                     style="max-height:200px; border-radius:8px; border:1px solid #eee;" />
            </div>
        </div>

        <div class="mb-4">
            <label class="form-label fw-medium">Description <span class="text-muted fw-normal">(optional)</span></label>
            <textarea name="description" class="form-control" rows="4"
                      placeholder="e.g. Grilled chicken breast, 200g rice, salad with olive oil..."
                      style="border-radius:8px;"></textarea>
            <div class="form-text">The more detail you add, the better the analysis.</div>
        </div>

        <button type="submit" id="submitBtn" class="btn btn-dark w-100 py-2" style="border-radius:8px;">
            Analyse
        </button>
    </form>

    <!-- Thinking panel — shown while Gemini streams its reasoning -->
    <div id="thinkingPanel" class="d-none">
        <div class="d-flex align-items-center gap-2 mb-3">
            <span class="spinner-border spinner-border-sm text-muted"></span>
            <span class="fw-medium text-muted" id="thinkingLabel">Gemini is thinking...</span>
        </div>
        <div id="thinkingText"
             class="border rounded p-3 small"
             style="max-height:260px; overflow-y:auto; white-space:pre-wrap; background:#f8f9fa; line-height:1.6;"></div>
        <p class="text-muted small mt-2 mb-0">Hang tight — results will appear automatically when done.</p>
    </div>
</div>

@section Scripts {
<script>
    const fileInput  = document.getElementById('fileInput');
    const previewBox = document.getElementById('previewBox');
    const imgPreview = document.getElementById('imgPreview');
    const form       = document.getElementById('analyseForm');
    const errorBox   = document.getElementById('errorBox');
    const thinkingPanel = document.getElementById('thinkingPanel');
    const thinkingText  = document.getElementById('thinkingText');
    const thinkingLabel = document.getElementById('thinkingLabel');

    fileInput.addEventListener('change', () => {
        const file = fileInput.files[0];
        if (file && file.type.startsWith('image/')) {
            imgPreview.src = URL.createObjectURL(file);
            previewBox.classList.remove('d-none');
        } else {
            previewBox.classList.add('d-none');
        }
    });

    form.addEventListener('submit', async (e) => {
        e.preventDefault();

        errorBox.classList.add('d-none');
        form.classList.add('d-none');
        thinkingPanel.classList.remove('d-none');
        thinkingText.textContent = '';

        let response;
        try {
            response = await fetch('/Nutrition/AnalyzeStream', {
                method: 'POST',
                body: new FormData(form)
            });
        } catch {
            showError('Network error. Please try again.');
            return;
        }

        if (!response.ok) {
            showError('Server error. Please try again.');
            return;
        }

        const reader  = response.body.getReader();
        const decoder = new TextDecoder();
        let buffer = '';

        while (true) {
            const { done, value } = await reader.read();
            if (done) break;

            buffer += decoder.decode(value, { stream: true });
            const lines = buffer.split('\n');
            buffer = lines.pop(); // keep partial last line

            for (const line of lines) {
                if (!line.startsWith('data: ')) continue;
                let data;
                try { data = JSON.parse(line.slice(6)); } catch { continue; }

                if (data.type === 'thinking') {
                    const span = document.createElement('span');
                    span.style.color = '#555';
                    span.textContent = data.text;
                    thinkingText.appendChild(span);
                    thinkingText.scrollTop = thinkingText.scrollHeight;
                } else if (data.type === 'output') {
                    const span = document.createElement('span');
                    span.style.color = '#999';
                    span.style.fontSize = '0.8em';
                    span.textContent = data.text;
                    thinkingText.appendChild(span);
                    thinkingLabel.textContent = 'Gemini is responding...';
                    thinkingText.scrollTop = thinkingText.scrollHeight;
                } else if (data.type === 'done') {
                    window.location.href = data.redirectUrl;
                } else if (data.type === 'error') {
                    showError(data.message);
                }
            }
        }
    });

    function showError(msg) {
        thinkingPanel.classList.add('d-none');
        form.classList.remove('d-none');
        errorBox.textContent = msg;
        errorBox.classList.remove('d-none');
    }
</script>
}
