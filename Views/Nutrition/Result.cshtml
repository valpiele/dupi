@model dupi.Models.NutritionPlan
@{
    ViewData["Title"] = Model.Title;
    var scoreColor = Model.Score >= 8 ? "#22c55e" : Model.Score >= 5 ? "#f59e0b" : "#ef4444";
    var scoreBg = Model.Score >= 8 ? "#f0fdf4" : Model.Score >= 5 ? "#fffbeb" : "#fef2f2";
    var totalMacros = Model.Proteins + Model.Carbohydrates + Model.Fats;
    double pPct = totalMacros > 0 ? Model.Proteins / totalMacros * 100 : 33;
    double cPct = totalMacros > 0 ? Model.Carbohydrates / totalMacros * 100 : 33;
    double fPct = totalMacros > 0 ? Model.Fats / totalMacros * 100 : 34;
}

<div style="max-width:680px; margin: 0 auto;">
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h2 class="fw-bold mb-0">@Model.Title</h2>
            <div class="d-flex align-items-center gap-2">
                <p class="text-muted small mb-0">@Model.CreatedAt.ToString("MMMM d, yyyy · HH:mm")</p>
                @if (!string.IsNullOrEmpty(Model.MealType))
                {
                    var mtEmoji = Model.MealType switch { "breakfast" => "🌅", "lunch" => "☀️", "dinner" => "🌙", "snack" => "🍎", _ => "🍽️" };
                    <span style="background:#f3f4f6; color:#555; border-radius:4px; padding:1px 6px; font-size:0.75rem; font-weight:500;">@mtEmoji @(char.ToUpper(Model.MealType[0]) + Model.MealType[1..])</span>
                }
            </div>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm" style="border-radius:6px;">← Back</a>
    </div>

    @if (Model.HasFile && Model.InputType == "image")
    {
        <div class="mb-4">
            <img src="@Url.Action("File", new { id = Model.Id })"
                 alt="Uploaded meal"
                 style="max-width:100%; max-height:320px; border-radius:12px; border:1px solid #eee; object-fit:cover;" />
        </div>
    }

    @if (Model.HasFile && Model.InputType == "pdf")
    {
        <div class="mb-4">
            <a href="@Url.Action("File", new { id = Model.Id })" target="_blank"
               class="btn btn-outline-dark btn-sm" style="border-radius:6px;">📄 View uploaded PDF</a>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.FoodDescription))
    {
        <p class="text-muted mb-4" style="font-size:0.95rem;">@Model.FoodDescription</p>
    }

    <div class="row g-3 mb-3">
        <div class="col-5 col-sm-4">
            <div class="card h-100 border-0 text-center" style="border-radius:12px; background:@scoreBg; padding:1.25rem 0;">
                <div style="font-size:2.8rem; font-weight:800; color:@scoreColor; line-height:1;">@Model.Score</div>
                <div style="font-size:0.75rem; color:@scoreColor; font-weight:600; text-transform:uppercase; letter-spacing:.05em;">/ 10</div>
                <div class="text-muted mt-1" style="font-size:0.75rem;">Score</div>
            </div>
        </div>
        <div class="col-7 col-sm-8">
            <div class="card h-100 border" style="border-radius:12px; border-color:#eee !important; padding:1.25rem;">
                <div class="text-muted small mb-1">🔥 Estimated Calories</div>
                <div style="font-size:1.6rem; font-weight:700;">@Model.CaloriesMin–@Model.CaloriesMax</div>
                <div class="text-muted small">kcal</div>
                @if (!string.IsNullOrEmpty(Model.ScoreSummary))
                {
                    <div class="mt-2 text-muted" style="font-size:0.8rem; line-height:1.4;">@Model.ScoreSummary</div>
                }
            </div>
        </div>
    </div>

    <div class="card border mb-3" style="border-radius:12px; border-color:#eee !important;">
        <div class="card-body p-3">
            <div class="text-muted small mb-2 fw-semibold">📊 Macronutrients</div>
            <div class="d-flex gap-3 mb-2">
                <div class="text-center flex-fill">
                    <div style="font-size:1.3rem; font-weight:700; color:#3b82f6;">@Model.Proteins.ToString("0.#")g</div>
                    <div class="text-muted" style="font-size:0.75rem;">Protein</div>
                </div>
                <div class="text-center flex-fill">
                    <div style="font-size:1.3rem; font-weight:700; color:#f59e0b;">@Model.Carbohydrates.ToString("0.#")g</div>
                    <div class="text-muted" style="font-size:0.75rem;">Carbs</div>
                </div>
                <div class="text-center flex-fill">
                    <div style="font-size:1.3rem; font-weight:700; color:#ec4899;">@Model.Fats.ToString("0.#")g</div>
                    <div class="text-muted" style="font-size:0.75rem;">Fats</div>
                </div>
            </div>
            <div style="height:8px; border-radius:4px; overflow:hidden; background:#f3f4f6; display:flex;">
                <div style="width:@pPct.ToString("0.#")%; background:#3b82f6;"></div>
                <div style="width:@cPct.ToString("0.#")%; background:#f59e0b;"></div>
                <div style="width:@fPct.ToString("0.#")%; background:#ec4899;"></div>
            </div>
        </div>
    </div>

    @if (Model.WhatsGood.Any())
    {
        <div class="card border mb-3" style="border-radius:12px; border-color:#eee !important;">
            <div class="card-body p-3">
                <div class="fw-semibold small mb-2">✅ What's Good</div>
                <ul class="mb-0" style="padding-left:1.25rem;">
                    @foreach (var item in Model.WhatsGood)
                    {
                        <li class="text-muted small mb-1">@item</li>
                    }
                </ul>
            </div>
        </div>
    }

    @if (Model.WhatToImprove.Any())
    {
        <div class="card border mb-4" style="border-radius:12px; border-color:#eee !important;">
            <div class="card-body p-3">
                <div class="fw-semibold small mb-2">💡 What to Improve</div>
                <ul class="mb-0" style="padding-left:1.25rem;">
                    @foreach (var item in Model.WhatToImprove)
                    {
                        <li class="text-muted small mb-1">@item</li>
                    }
                </ul>
            </div>
        </div>
    }

    <div class="d-flex gap-2">
        <a asp-action="Create" class="btn btn-dark btn-sm px-3" style="border-radius:6px;">+ New analysis</a>
        <form asp-action="Delete" method="post" onsubmit="return confirm('Delete this plan?')">
            <input type="hidden" name="id" value="@Model.Id" />
            <button type="submit" class="btn btn-outline-danger btn-sm px-3" style="border-radius:6px;">Delete</button>
        </form>
    </div>
</div>
