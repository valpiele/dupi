@model dupi.Models.NutritionIndexViewModel
@{
    ViewData["Title"] = "Nutrition";

    var mealsJson = System.Text.Json.JsonSerializer.Serialize(
        Model.Plans.Where(p => p.Score > 0 || p.CaloriesMin > 0)
             .OrderBy(p => p.CreatedAt)
             .Select(p => new {
                 score    = p.Score,
                 calMid   = (p.CaloriesMin + p.CaloriesMax) / 2.0,
                 proteins = p.Proteins,
                 carbs    = p.Carbohydrates,
                 fats     = p.Fats,
                 iso      = p.CreatedAt.ToLocalTime().ToString("o"),
                 label    = p.CreatedAt.ToLocalTime().ToString("MMM d HH:mm"),
                 title    = p.Title
             })
    );

    bool hasChartData = Model.Plans.Any(p => p.Score > 0 || p.CaloriesMin > 0);

    // Today summary
    var todayMealCount  = Model.TodayPlans.Count;
    var todayCalMin     = Model.TodayPlans.Sum(p => p.CaloriesMin);
    var todayCalMax     = Model.TodayPlans.Sum(p => p.CaloriesMax);
    var todayProtein    = Model.TodayPlans.Sum(p => p.Proteins);
    var todayCarbs      = Model.TodayPlans.Sum(p => p.Carbohydrates);
    var todayFat        = Model.TodayPlans.Sum(p => p.Fats);
    var todayMacrosTotal = todayProtein + todayCarbs + todayFat;
    double todayPPct    = todayMacrosTotal > 0 ? todayProtein / todayMacrosTotal * 100 : 0;
    double todayCPct    = todayMacrosTotal > 0 ? todayCarbs   / todayMacrosTotal * 100 : 0;
    double todayFPct    = todayMacrosTotal > 0 ? todayFat     / todayMacrosTotal * 100 : 0;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-0 fw-bold">Nutrition</h2>
        <p class="text-muted small mb-0">Your meal and nutrition plan analyses.</p>
    </div>
    <a asp-action="Create" class="btn btn-dark px-4" style="border-radius:8px;">+ Analyse a meal</a>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (!Model.Plans.Any())
{
    <div class="text-center py-5 text-muted">
        <div style="font-size:3rem;">🥗</div>
        <p class="mt-2">No analyses yet. Upload a meal photo or describe your plan to get started.</p>
        <a asp-action="Create" class="btn btn-outline-dark mt-2" style="border-radius:8px;">Analyse your first meal</a>
    </div>
}
else
{
    @* ── Today's Summary ── *@
    <div class="card border mb-4" style="border-radius:12px; border-color:#eee !important;">
        <div class="card-body p-3">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <span class="fw-semibold small">Today</span>
                <span class="text-muted small">
                    @todayMealCount meal@(todayMealCount != 1 ? "s" : "") logged
                </span>
            </div>
            @if (todayMealCount > 0)
            {
                <div class="d-flex flex-wrap align-items-baseline gap-3 mb-2">
                    <div>
                        <span class="fw-bold" style="font-size:1.15rem;">@todayCalMin–@todayCalMax</span>
                        <span class="text-muted small"> kcal</span>
                    </div>
                    <div class="d-flex gap-3">
                        <span style="color:#3b82f6; font-weight:600; font-size:0.88rem;">P @todayProtein.ToString("0")g</span>
                        <span style="color:#f59e0b; font-weight:600; font-size:0.88rem;">C @todayCarbs.ToString("0")g</span>
                        <span style="color:#ec4899; font-weight:600; font-size:0.88rem;">F @todayFat.ToString("0")g</span>
                    </div>
                </div>
                @if (todayMacrosTotal > 0)
                {
                    <div style="height:6px; border-radius:3px; overflow:hidden; background:#f3f4f6; display:flex;">
                        <div style="width:@todayPPct.ToString("0.#")%; background:#3b82f6;"></div>
                        <div style="width:@todayCPct.ToString("0.#")%; background:#f59e0b;"></div>
                        <div style="width:@todayFPct.ToString("0.#")%; background:#ec4899;"></div>
                    </div>
                }
            }
            else
            {
                <p class="text-muted small mb-0">No meals logged today. <a asp-action="Create" class="text-dark">Log your first meal of the day →</a></p>
            }
        </div>
    </div>

    @* ── History Charts ── *@
    @if (hasChartData)
    {
        <div class="card border mb-4" style="border-radius:12px; border-color:#eee !important;">
            <div class="card-body p-3">
                <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-2">
                    <div class="btn-group btn-group-sm" role="group">
                        <button type="button" class="btn btn-dark"         onclick="setChartTab('score')"    id="ctab-score">Score</button>
                        <button type="button" class="btn btn-outline-dark" onclick="setChartTab('calories')" id="ctab-calories">Calories</button>
                        <button type="button" class="btn btn-outline-dark" onclick="setChartTab('macros')"   id="ctab-macros">Macros</button>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <div class="btn-group btn-group-sm" role="group">
                            <button type="button" class="btn btn-outline-secondary" onclick="setMode('meal')" id="btn-meal">Meal</button>
                            <button type="button" class="btn btn-outline-secondary" onclick="setMode('day')"  id="btn-day">Day</button>
                            <button type="button" class="btn btn-outline-secondary" onclick="setMode('week')" id="btn-week">Week</button>
                        </div>
                        <div class="d-flex align-items-center gap-1">
                            <button class="btn btn-outline-secondary btn-sm px-2" id="btnOlder" onclick="changePage(1)">‹</button>
                            <span class="text-muted small" id="pageInfo" style="white-space:nowrap;"></span>
                            <button class="btn btn-outline-secondary btn-sm px-2" id="btnNewer" onclick="changePage(-1)">›</button>
                        </div>
                    </div>
                </div>
                <canvas id="nutritionChart" height="80"></canvas>
            </div>
        </div>
    }

    @* ── Meal Cards ── *@
    <div class="row g-3">
        @foreach (var plan in Model.Plans)
        {
            var scoreColor = plan.Score >= 8 ? "#22c55e" : plan.Score >= 5 ? "#f59e0b" : plan.Score > 0 ? "#ef4444" : "#9ca3af";
            var scoreBg   = plan.Score >= 8 ? "#f0fdf4" : plan.Score >= 5 ? "#fffbeb" : plan.Score > 0 ? "#fef2f2" : "#f9fafb";
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 border" style="border-radius:12px; border-color:#eee !important;">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h6 class="fw-semibold mb-0" style="max-width:75%;">@plan.Title</h6>
                            @if (plan.Score > 0)
                            {
                                <span style="background:@scoreBg; color:@scoreColor; border-radius:6px; padding:2px 8px; font-size:0.8rem; font-weight:700; white-space:nowrap;">
                                    @plan.Score/10
                                </span>
                            }
                        </div>
                        <div class="d-flex align-items-center gap-2 mb-1">
                            <span class="text-muted small">@plan.CreatedAt.ToString("MMM d, yyyy · HH:mm")</span>
                            @if (!string.IsNullOrEmpty(plan.MealType))
                            {
                                var mtEmoji = plan.MealType switch { "breakfast" => "🌅", "lunch" => "☀️", "dinner" => "🌙", "snack" => "🍎", _ => "🍽️" };
                                <span style="background:#f3f4f6; color:#555; border-radius:4px; padding:1px 6px; font-size:0.72rem; font-weight:500;">@mtEmoji @(char.ToUpper(plan.MealType[0]) + plan.MealType[1..])</span>
                            }
                        </div>
                        @if (plan.CaloriesMin > 0)
                        {
                            <p class="text-muted small mb-2" style="font-size:0.78rem;">🔥 @plan.CaloriesMin–@plan.CaloriesMax kcal</p>
                        }
                        @if (!string.IsNullOrEmpty(plan.FoodDescription))
                        {
                            <p class="text-muted mb-3" style="font-size:0.82rem; line-height:1.4; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;">
                                @plan.FoodDescription
                            </p>
                        }
                        <a asp-action="Result" asp-route-id="@plan.Id"
                           class="btn btn-sm btn-outline-dark w-100" style="border-radius:6px;">View analysis</a>
                    </div>
                    <div class="card-footer bg-transparent border-0 pt-0 pb-3 px-3">
                        <form asp-action="Delete" method="post" class="d-inline"
                              onsubmit="return confirm('Delete this plan?')">
                            <input type="hidden" name="id" value="@plan.Id" />
                            <button type="submit" class="btn btn-sm btn-link text-danger p-0"
                                    style="font-size:0.8rem;">Delete</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}

@section Scripts {
@if (hasChartData)
{
<script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
<script>
const RAW = @Html.Raw(mealsJson);
const PAGE_SIZE = 100;
let mode     = 'meal';  // meal | day | week
let chartTab = 'score'; // score | calories | macros
let page = 0;
let chart = null;

const avg = arr => arr.length ? arr.reduce((a, b) => a + b, 0) / arr.length : 0;
const sum = arr => arr.reduce((a, b) => a + b, 0);

function isoWeekKey(iso) {
    const d = new Date(iso);
    d.setHours(0, 0, 0, 0);
    d.setDate(d.getDate() + 3 - (d.getDay() + 6) % 7);
    const jan4 = new Date(d.getFullYear(), 0, 4);
    const wk = 1 + Math.round(((d - jan4) / 86400000 - 3 + (jan4.getDay() + 6) % 7) / 7);
    return `${d.getFullYear()}-W${String(wk).padStart(2, '0')}`;
}
function weekLabel(iso) {
    const d = new Date(iso);
    const mon = new Date(d);
    mon.setDate(d.getDate() - (d.getDay() === 0 ? 6 : d.getDay() - 1));
    return 'W/o ' + mon.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}
function dayLabel(iso) {
    return new Date(iso).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}

function buildGroups() {
    if (mode === 'meal') {
        return RAW.map(m => ({ label: m.label, score: m.score, calMid: m.calMid, proteins: m.proteins, carbs: m.carbs, fats: m.fats }));
    }
    const map = new Map();
    RAW.forEach(m => {
        const key   = mode === 'day' ? m.iso.slice(0, 10) : isoWeekKey(m.iso);
        const label = mode === 'day' ? dayLabel(m.iso)    : weekLabel(m.iso);
        if (!map.has(key)) map.set(key, { label, scores: [], calMids: [], proteins: [], carbs: [], fats: [] });
        const g = map.get(key);
        if (m.score > 0) g.scores.push(m.score);
        g.calMids.push(m.calMid);
        g.proteins.push(m.proteins);
        g.carbs.push(m.carbs);
        g.fats.push(m.fats);
    });
    return Array.from(map.values()).map(g => ({
        label:    g.label,
        score:    g.scores.length ? Math.round(avg(g.scores) * 10) / 10 : 0,
        calMid:   Math.round(sum(g.calMids)),
        proteins: Math.round(sum(g.proteins) * 10) / 10,
        carbs:    Math.round(sum(g.carbs) * 10) / 10,
        fats:     Math.round(sum(g.fats) * 10) / 10
    }));
}

const sharedScaleX = { grid: { display: false }, ticks: { maxRotation: 45, maxTicksLimit: 20 } };

function buildChartConfig(slice) {
    if (chartTab === 'score') {
        return {
            type: 'line',
            data: {
                labels: slice.map(g => g.label),
                datasets: [{ label: 'Score', data: slice.map(g => g.score),
                    borderColor: '#3b82f6', backgroundColor: 'rgba(59,130,246,0.08)',
                    borderWidth: 2, pointBackgroundColor: '#3b82f6', pointRadius: 4, tension: 0.3, fill: true }]
            },
            options: { animation: false, responsive: true, maintainAspectRatio: true,
                scales: { y: { min: 0, max: 10, ticks: { stepSize: 2 }, grid: { color: '#f3f4f6' } }, x: sharedScaleX },
                plugins: { legend: { display: false } } }
        };
    }
    if (chartTab === 'calories') {
        return {
            type: 'bar',
            data: {
                labels: slice.map(g => g.label),
                datasets: [{ label: 'kcal', data: slice.map(g => g.calMid),
                    backgroundColor: 'rgba(59,130,246,0.7)', borderColor: '#3b82f6',
                    borderWidth: 1, borderRadius: 4 }]
            },
            options: { animation: false, responsive: true, maintainAspectRatio: true,
                scales: { y: { beginAtZero: true, grid: { color: '#f3f4f6' } }, x: sharedScaleX },
                plugins: { legend: { display: false } } }
        };
    }
    // macros
    return {
        type: 'bar',
        data: {
            labels: slice.map(g => g.label),
            datasets: [
                { label: 'Protein (g)', data: slice.map(g => g.proteins), backgroundColor: 'rgba(59,130,246,0.8)', borderRadius: 4 },
                { label: 'Carbs (g)',   data: slice.map(g => g.carbs),    backgroundColor: 'rgba(245,158,11,0.8)', borderRadius: 4 },
                { label: 'Fat (g)',     data: slice.map(g => g.fats),     backgroundColor: 'rgba(236,72,153,0.8)', borderRadius: 4 }
            ]
        },
        options: { animation: false, responsive: true, maintainAspectRatio: true,
            scales: { y: { beginAtZero: true, stacked: true, grid: { color: '#f3f4f6' } }, x: { ...sharedScaleX, stacked: true } },
            plugins: { legend: { display: true, position: 'bottom', labels: { boxWidth: 12, font: { size: 11 } } } } }
    };
}

function render() {
    const groups = buildGroups();
    const total  = groups.length;
    const maxPage = Math.max(0, Math.ceil(total / PAGE_SIZE) - 1);
    page = Math.min(page, maxPage);

    const end   = total - page * PAGE_SIZE;
    const start = Math.max(0, end - PAGE_SIZE);
    const slice = groups.slice(start, end);

    const canvas = document.getElementById('nutritionChart');
    if (chart) chart.destroy();
    chart = new Chart(canvas, buildChartConfig(slice));

    const unit  = mode === 'meal' ? 'meal' : mode === 'day' ? 'day' : 'week';
    const units = unit + (total !== 1 ? 's' : '');
    document.getElementById('pageInfo').textContent =
        total > PAGE_SIZE ? `${start + 1}–${end} of ${total} ${units}` : `${total} ${units}`;
    document.getElementById('btnOlder').disabled = start <= 0;
    document.getElementById('btnNewer').disabled = page <= 0;
}

function setChartTab(t) {
    chartTab = t;
    page = 0;
    ['score', 'calories', 'macros'].forEach(x => {
        document.getElementById('ctab-' + x).className = x === t ? 'btn btn-dark btn-sm' : 'btn btn-outline-dark btn-sm';
    });
    render();
}

function setMode(m) {
    mode = m;
    page = 0;
    ['meal', 'day', 'week'].forEach(x => {
        document.getElementById('btn-' + x).className = x === m ? 'btn btn-outline-secondary btn-sm active' : 'btn btn-outline-secondary btn-sm';
    });
    render();
}

function changePage(dir) { page += dir; render(); }

setMode('meal'); // initialise active state and first render
</script>
}
}
