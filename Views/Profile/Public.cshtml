@model dupi.Models.UserProfile
@{
    ViewData["Title"] = Model.DisplayName;
    var projects = ViewBag.Projects as List<dupi.Models.Project> ?? new();
    var friendStatus = ViewBag.FriendStatus as string;
    var targetUserId = ViewBag.TargetUserId as string;
}

<div class="container mt-4">
    <div class="mb-4 d-flex align-items-start justify-content-between flex-wrap gap-3">
        <div>
            <h1 class="mb-0">@Model.DisplayName</h1>
            <div class="text-muted mb-2">&#64;@Model.Username</div>
            @if (!string.IsNullOrWhiteSpace(Model.Bio))
            {
                <p class="text-muted mb-0">@Model.Bio</p>
            }
        </div>

        @if (friendStatus != null && targetUserId != null)
        {
            <div class="flex-shrink-0">
                @if (friendStatus == "none")
                {
                    <form asp-controller="Friends" asp-action="SendRequest" method="post" class="m-0">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="receiverId" value="@targetUserId" />
                        <input type="hidden" name="returnUrl" value="/u/@Model.Username" />
                        <button type="submit" class="btn btn-dark btn-sm px-4">+ Add Friend</button>
                    </form>
                }
                else if (friendStatus == "pending_sent")
                {
                    <button class="btn btn-outline-secondary btn-sm px-4" disabled>Request Sent</button>
                }
                else if (friendStatus == "pending_received")
                {
                    <a href="/Friends#requests" class="btn btn-warning btn-sm px-4">Respond to Request</a>
                }
                else if (friendStatus == "friends")
                {
                    <div class="d-flex gap-2">
                        <a asp-controller="Chat" asp-action="Index" asp-route-friendId="@targetUserId"
                           class="btn btn-outline-primary btn-sm px-4">Message</a>
                        <form asp-controller="Friends" asp-action="Unfriend" method="post" class="m-0">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="otherId" value="@targetUserId" />
                            <input type="hidden" name="returnUrl" value="/u/@Model.Username" />
                            <button type="submit" class="btn btn-outline-secondary btn-sm"
                                    onclick="return confirm('Remove friend?')">Unfriend</button>
                        </form>
                    </div>
                }
            </div>
        }
    </div>

    <h5 class="mb-3">Projects (@projects.Count)</h5>
    @if (!projects.Any())
    {
        <p class="text-muted">No projects uploaded yet.</p>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var project in projects)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        <div class="pdf-thumb-container"
                             onclick="openPreview('@project.FileName', '@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(project.DisplayName))')"
                             style="cursor:pointer; height:220px; background:#f1f3f4; display:flex; align-items:center; justify-content:center; overflow:hidden; border-bottom:1px solid rgba(0,0,0,.1);">
                            <canvas class="pdf-thumb"
                                    data-src="/u/@Model.Username/view?fileName=@Uri.EscapeDataString(project.FileName)"
                                    style="max-width:100%; max-height:100%;"></canvas>
                        </div>
                        <div class="card-body py-2">
                            <h6 class="card-title text-truncate mb-0" title="@project.DisplayName">@project.DisplayName</h6>
                            <small class="text-muted">@project.FileSizeFormatted &middot; @project.UploadedAt.ToString("MMM d, yyyy")</small>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<div class="modal fade" id="previewModal" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content" style="height:90vh;">
            <div class="modal-header">
                <h5 class="modal-title" id="previewTitle"></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0" style="overflow:hidden; flex:1 1 auto;">
                <iframe id="previewFrame" src="" style="width:100%; height:100%; border:none;"></iframe>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
    <script>
        pdfjsLib.GlobalWorkerOptions.workerSrc =
            'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

        document.querySelectorAll('.pdf-thumb').forEach(canvas => {
            pdfjsLib.getDocument(canvas.dataset.src).promise
                .then(pdf => pdf.getPage(1))
                .then(page => {
                    const scale = canvas.parentElement.clientWidth / page.getViewport({ scale: 1 }).width;
                    const vp = page.getViewport({ scale });
                    canvas.width = vp.width;
                    canvas.height = vp.height;
                    page.render({ canvasContext: canvas.getContext('2d'), viewport: vp });
                });
        });

        function openPreview(fileName, displayName) {
            document.getElementById('previewTitle').textContent = displayName;
            document.getElementById('previewFrame').src =
                '/u/@Model.Username/view?fileName=' + encodeURIComponent(fileName);
            new bootstrap.Modal(document.getElementById('previewModal')).show();
        }

        document.getElementById('previewModal').addEventListener('hidden.bs.modal', function () {
            document.getElementById('previewFrame').src = '';
        });
    </script>
}
