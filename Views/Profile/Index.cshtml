@model dupi.Models.UserProfile
@{
    ViewData["Title"] = "My Profile";
    var projects = ViewBag.Projects as List<dupi.Models.Project> ?? new();
}

<div class="container mt-4" style="max-width: 700px;">
    <h1 class="mb-4">My Profile</h1>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <form asp-action="Save" asp-controller="Profile" method="post">
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Profile details</span>
                @if (Model.IsPublic && !string.IsNullOrEmpty(Model.Username))
                {
                    <a href="/u/@Model.Username" target="_blank" class="btn btn-sm btn-outline-success">View public page &rarr;</a>
                }
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Username</label>
                    <div class="input-group">
                        <span class="input-group-text text-muted">dupi.com/u/</span>
                        <input name="Username" value="@Model.Username" class="form-control"
                               placeholder="your-username" pattern="[a-zA-Z0-9_\-]{3,30}" />
                    </div>
                    <div class="form-text">3–30 characters. Letters, numbers, hyphens and underscores only.</div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Display name</label>
                    <input name="DisplayName" value="@Model.DisplayName" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Bio</label>
                    <textarea name="Bio" class="form-control" rows="3">@Model.Bio</textarea>
                </div>
                <div class="form-check form-switch mb-1">
                    <input class="form-check-input" type="checkbox" name="IsPublic" value="true"
                           id="isPublic" @(Model.IsPublic ? "checked" : "") />
                    <input type="hidden" name="IsPublic" value="false" />
                    <label class="form-check-label" for="isPublic">Make my profile public</label>
                </div>
                <small class="text-muted">When public, anyone can find you on the Discover page and view your projects.</small>
            </div>
            <div class="card-footer text-end">
                <button type="submit" class="btn btn-primary">Save</button>
            </div>
        </div>
    </form>

    <h5 class="mb-3">My Projects (@projects.Count)</h5>
    @if (!projects.Any())
    {
        <p class="text-muted">No projects yet. <a asp-controller="Projects" asp-action="Index">Upload one</a>.</p>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 g-3">
            @foreach (var p in projects)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        <div style="height:140px; background:#f1f3f4; display:flex; align-items:center; justify-content:center; overflow:hidden; border-bottom:1px solid rgba(0,0,0,.1);">
                            <canvas class="pdf-thumb"
                                    data-src="/Projects/View?fileName=@Uri.EscapeDataString(p.FileName)"
                                    style="max-width:100%; max-height:100%;"></canvas>
                        </div>
                        <div class="card-body py-2">
                            <p class="mb-0 text-truncate small fw-semibold" title="@p.DisplayName">@p.DisplayName</p>
                            <small class="text-muted">@p.FileSizeFormatted</small>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
    <script>
        pdfjsLib.GlobalWorkerOptions.workerSrc =
            'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

        document.querySelectorAll('.pdf-thumb').forEach(canvas => {
            pdfjsLib.getDocument(canvas.dataset.src).promise
                .then(pdf => pdf.getPage(1))
                .then(page => {
                    const scale = canvas.parentElement.clientWidth / page.getViewport({ scale: 1 }).width;
                    const vp = page.getViewport({ scale });
                    canvas.width = vp.width;
                    canvas.height = vp.height;
                    page.render({ canvasContext: canvas.getContext('2d'), viewport: vp });
                });
        });
    </script>
}
