@using dupi.Models
@{
    ViewData["Title"] = "Chat";
    var conversations = ViewBag.Conversations as List<(string FriendId, UserProfile? Profile, Message Last, int Unread)> ?? new();
    var messages     = ViewBag.Messages as List<Message> ?? new();
    var activeFriendId = ViewBag.ActiveFriendId as string;
    var friendProfile  = ViewBag.FriendProfile as UserProfile;
    var myId = User.FindFirst("dupi:uid")?.Value ?? "";
}

<style>
    .chat-layout {
        display: flex;
        height: calc(100vh - 100px);
        min-height: 400px;
        border: 1px solid #e5e5e5;
        border-radius: 12px;
        overflow: hidden;
    }
    .chat-sidebar {
        width: 300px;
        flex-shrink: 0;
        border-right: 1px solid #e5e5e5;
        overflow-y: auto;
        background: #fafafa;
    }
    .chat-main {
        flex: 1;
        display: flex;
        flex-direction: column;
        min-width: 0;
    }
    .chat-header {
        padding: 14px 20px;
        border-bottom: 1px solid #e5e5e5;
        font-weight: 600;
        background: #fff;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .msg-area {
        flex: 1;
        overflow-y: auto;
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }
    .msg-footer {
        padding: 12px 16px;
        border-top: 1px solid #e5e5e5;
        background: #fff;
        display: flex;
        gap: 8px;
    }
    .convo-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 14px;
        cursor: pointer;
        text-decoration: none;
        color: inherit;
        border-bottom: 1px solid #ececec;
        transition: background .1s;
    }
    .convo-item:hover, .convo-item.active { background: #f0f0f0; }
    .convo-avatar {
        width: 40px; height: 40px;
        border-radius: 50%;
        background: #1a1a1a;
        color: #fff;
        font-weight: 700;
        font-size: 0.9rem;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }
    .convo-last {
        font-size: 0.78rem;
        color: #888;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 160px;
    }
    .bubble {
        max-width: 70%;
        padding: 8px 14px;
        border-radius: 18px;
        font-size: 0.9rem;
        line-height: 1.4;
        word-break: break-word;
    }
    .bubble-out {
        background: #1a1a1a;
        color: #fff;
        border-bottom-right-radius: 4px;
        align-self: flex-end;
    }
    .bubble-in {
        background: #f0f0f0;
        color: #1a1a1a;
        border-bottom-left-radius: 4px;
        align-self: flex-start;
    }
    .bubble-time {
        font-size: 0.7rem;
        opacity: 0.55;
        margin-top: 2px;
        text-align: right;
    }
    .msg-group { display: flex; flex-direction: column; }
    .msg-group.out { align-items: flex-end; }
    .msg-group.in  { align-items: flex-start; }
    @@media (max-width: 640px) {
        .chat-sidebar { width: 64px; }
        .convo-info { display: none; }
    }
</style>

<div class="chat-layout mt-3">
    <!-- Sidebar: conversation list -->
    <div class="chat-sidebar">
        <div class="p-3 border-bottom fw-semibold small text-muted text-uppercase" style="letter-spacing:.05rem;">Messages</div>
        @if (!conversations.Any())
        {
            <div class="p-3 text-muted small text-center mt-4">No conversations yet.<br />
                <a asp-controller="Friends" asp-action="Index" class="text-primary">Find friends</a>
            </div>
        }
        @foreach (var (fid, prof, last, unread) in conversations)
        {
            var name = prof?.DisplayName ?? "User";
            var isActive = fid == activeFriendId;
            <a href="/Chat?friendId=@fid" class="convo-item @(isActive ? "active" : "")">
                <div class="convo-avatar">@name.FirstOrDefault().ToString().ToUpper()</div>
                <div class="convo-info overflow-hidden flex-grow-1">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="fw-semibold small text-truncate">@name</span>
                        @if (unread > 0)
                        {
                            <span class="badge bg-danger rounded-pill ms-1" style="font-size:.65rem;">@unread</span>
                        }
                    </div>
                    <div class="convo-last">@last.Content</div>
                </div>
            </a>
        }
    </div>

    <!-- Main panel -->
    <div class="chat-main">
        @if (activeFriendId == null || friendProfile == null)
        {
            <div class="d-flex align-items-center justify-content-center h-100 text-muted">
                Select a conversation to start chatting
            </div>
        }
        else
        {
            <div class="chat-header">
                <div class="convo-avatar" style="width:32px;height:32px;font-size:0.8rem;">
                    @friendProfile.DisplayName.FirstOrDefault().ToString().ToUpper()
                </div>
                <span>@friendProfile.DisplayName</span>
                @if (!string.IsNullOrEmpty(friendProfile.Username))
                {
                    <span class="text-muted small fw-normal">&#64;@friendProfile.Username</span>
                }
            </div>

            <div class="msg-area" id="msgArea">
                <button id="loadMoreBtn" class="btn btn-sm btn-outline-secondary align-self-center d-none" onclick="loadMore()">
                    Load earlier messages
                </button>
                <div id="messages">
                    @foreach (var m in messages)
                    {
                        var isOut = m.SenderId == myId;
                        <div class="msg-group @(isOut ? "out" : "in")" data-msg-id="@m.Id">
                            <div class="bubble @(isOut ? "bubble-out" : "bubble-in")">@m.Content</div>
                            <div class="bubble-time">@m.SentAt.ToString("HH:mm")</div>
                        </div>
                    }
                </div>
            </div>

            <form class="msg-footer" id="msgForm" onsubmit="sendMessage(event)">
                <input type="text" id="msgInput" class="form-control form-control-sm"
                       placeholder="Message @friendProfile.DisplayName..." autocomplete="off" maxlength="2000" />
                <button type="submit" class="btn btn-dark btn-sm px-4">Send</button>
            </form>
        }
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.0/dist/browser/signalr.min.js"></script>
    <script>
        const myId = '@myId';
        const activeFriendId = '@activeFriendId';
        let skipCount = @messages.Count;
        const pageSize = 60;

        const connection = new signalR.HubConnectionBuilder()
            .withUrl('/chatHub')
            .withAutomaticReconnect()
            .build();

        connection.on('ReceiveMessage', msg => {
            if (msg.senderId !== activeFriendId && msg.senderId !== myId) return;
            appendMessage(msg.senderId === myId, msg.content, new Date(msg.sentAt));
            if (msg.senderId === activeFriendId) {
                connection.invoke('MarkRead', activeFriendId).catch(() => {});
            }
        });

        connection.on('MessagesRead', senderId => {
            // could add read receipts UI here
        });

        connection.start().then(() => {
            if (activeFriendId) connection.invoke('MarkRead', activeFriendId).catch(() => {});
            scrollToBottom();
            if (skipCount >= pageSize) document.getElementById('loadMoreBtn')?.classList.remove('d-none');
        }).catch(console.error);

        function appendMessage(isOut, content, date) {
            const area = document.getElementById('messages');
            const div = document.createElement('div');
            div.className = `msg-group ${isOut ? 'out' : 'in'}`;
            div.innerHTML = `<div class="bubble ${isOut ? 'bubble-out' : 'bubble-in'}">${escHtml(content)}</div>`
                          + `<div class="bubble-time">${formatTime(date)}</div>`;
            area.appendChild(div);
            scrollToBottom();
        }

        function sendMessage(e) {
            e.preventDefault();
            const input = document.getElementById('msgInput');
            const text = input.value.trim();
            if (!text || !activeFriendId) return;
            input.value = '';
            connection.invoke('SendMessage', activeFriendId, text).catch(console.error);
        }

        async function loadMore() {
            const btn = document.getElementById('loadMoreBtn');
            btn.disabled = true;
            const res = await fetch(`/Chat/History?friendId=${activeFriendId}&skip=${skipCount}`);
            const msgs = await res.json();
            if (msgs.length < pageSize) btn.remove();
            else { btn.disabled = false; skipCount += msgs.length; }

            const area = document.getElementById('messages');
            msgs.reverse().forEach(m => {
                const div = document.createElement('div');
                const isOut = m.senderId === myId;
                div.className = `msg-group ${isOut ? 'out' : 'in'}`;
                div.innerHTML = `<div class="bubble ${isOut ? 'bubble-out' : 'bubble-in'}">${escHtml(m.content)}</div>`
                              + `<div class="bubble-time">${formatTime(new Date(m.sentAt))}</div>`;
                area.prepend(div);
            });
        }

        function scrollToBottom() {
            const a = document.getElementById('msgArea');
            if (a) a.scrollTop = a.scrollHeight;
        }

        function escHtml(str) {
            return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
        }

        function formatTime(d) {
            return d.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
        }
    </script>
}
