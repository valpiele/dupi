@model ErrorViewModel
@{
    ViewData["Title"] = "Something went wrong";
}

<div class="container mt-5" style="max-width: 560px;">
    <h2 class="mb-2">Something went wrong</h2>
    <p class="text-muted">We're having trouble completing your request right now. This is usually temporary — please try again in a moment.</p>
    @if (Model.ShowRequestId)
    {
        <p class="text-muted small mt-4">Request ID: <code>@Model.RequestId</code></p>
    }
    <a href="/" class="btn btn-outline-primary mt-2">Go home</a>
</div>
