<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - dupi</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/dupi.styles.css" asp-append-version="true" />
    <style>
        .navbar-brand {
            font-weight: 700;
            font-size: 1.2rem;
            letter-spacing: -0.5px;
            color: #1a1a1a !important;
        }
        .nav-link {
            color: #555 !important;
            font-size: 0.9rem;
        }
        .nav-link:hover { color: #000 !important; }

        .avatar-btn {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            border: none;
            background: #1a1a1a;
            color: #fff;
            font-size: 0.85rem;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: opacity .15s;
        }
        .avatar-btn:hover { opacity: 0.85; }

        .avatar-dropdown .dropdown-menu {
            min-width: 210px;
            border: 1px solid #e5e5e5;
            box-shadow: 0 8px 24px rgba(0,0,0,.1);
            border-radius: 12px;
            padding: 8px;
            margin-top: 8px !important;
        }
        .avatar-dropdown .dropdown-item {
            border-radius: 8px;
            font-size: 0.88rem;
            padding: 8px 12px;
        }
        .avatar-dropdown .dropdown-item:hover { background: #f5f5f5; }
        .avatar-dropdown .dropdown-divider { margin: 6px 0; }
        .avatar-email {
            font-size: 0.78rem;
            color: #888;
            padding: 6px 12px 8px;
            display: block;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 200px;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm bg-white border-bottom mb-3" style="padding: 0.5rem 1rem;">
            <div class="container-fluid px-0">
                <a class="navbar-brand me-4" asp-controller="Home" asp-action="Index">dupi</a>

                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex align-items-center justify-content-between">
                    <ul class="navbar-nav gap-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Projects" asp-action="Index">Projects</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Discover" asp-action="Index">Discover</a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Nutrition" asp-action="Index">Nutrition</a>
                            </li>
                            @await Component.InvokeAsync("SocialBadges")
                        }
                    </ul>

                    <div class="d-flex align-items-center">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <div class="dropdown avatar-dropdown">
                                <button class="avatar-btn" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    @User.Identity.Name![0].ToString().ToUpper()
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><span class="avatar-email">@User.Identity.Name</span></li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Profile" asp-action="Index">Settings</a>
                                    </li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                            <button type="submit" class="dropdown-item text-danger">Sign out</button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a class="btn btn-sm btn-dark px-3" asp-controller="Account" asp-action="Login">Sign in</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - dupi - <a asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
