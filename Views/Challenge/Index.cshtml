@model dupi.Models.ChallengeIndexViewModel
@{
    ViewData["Title"] = "Challenges";
}

<div class="container mt-4" style="max-width:760px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-0 fw-bold">Challenges</h2>
            <p class="text-muted small mb-0">Compete with friends on 7-day protein targets.</p>
        </div>
        <a asp-action="Create" class="btn btn-dark px-4" style="border-radius:8px;">+ New Challenge</a>
    </div>

    <ul class="nav nav-tabs mb-4" id="challengeTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-active" type="button">
                Active <span class="badge bg-secondary ms-1">@Model.ActiveChallenges.Count</span>
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-invites" type="button">
                Invites
                @if (Model.PendingInvites.Count > 0)
                {
                    <span class="badge bg-danger ms-1">@Model.PendingInvites.Count</span>
                }
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-community" type="button">
                Community <span class="badge bg-secondary ms-1">@Model.CommunityChallenges.Count</span>
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-completed" type="button">
                Completed <span class="badge bg-secondary ms-1">@Model.CompletedChallenges.Count</span>
            </button>
        </li>
    </ul>

    <div class="tab-content">
        <!-- Active tab -->
        <div class="tab-pane fade show active" id="tab-active">
            @if (!Model.ActiveChallenges.Any())
            {
                <div class="text-center py-5">
                    <p class="text-muted mb-3">No active challenges right now.</p>
                    <a asp-action="Create" class="btn btn-dark btn-sm px-4">Create one</a>
                </div>
            }
            else
            {
                <div class="d-flex flex-column gap-3">
                    @foreach (var (challenge, count, rank, daysHit) in Model.ActiveChallenges)
                    {
                        var dayNum = Math.Min(7, (int)(DateTime.UtcNow - challenge.StartDate).TotalDays + 1);
                        <a asp-action="Dashboard" asp-route-id="@challenge.Id" class="text-decoration-none">
                            <div class="card shadow-sm">
                                <div class="card-body py-3">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <h6 class="fw-semibold mb-1 text-dark">@challenge.Title</h6>
                                            <div class="text-muted small">
                                                @challenge.ProteinTargetGrams g protein/day &middot;
                                                Day @dayNum of 7 &middot;
                                                @count participant@(count != 1 ? "s" : "")
                                            </div>
                                        </div>
                                        <span class="badge bg-success">Active</span>
                                    </div>
                                </div>
                            </div>
                        </a>
                    }
                </div>
            }
        </div>

        <!-- Invites tab -->
        <div class="tab-pane fade" id="tab-invites">
            @if (!Model.PendingInvites.Any())
            {
                <p class="text-muted py-4 text-center">No pending challenge invites.</p>
            }
            else
            {
                <div class="d-flex flex-column gap-3">
                    @foreach (var (challenge, count) in Model.PendingInvites)
                    {
                        <div class="card shadow-sm">
                            <div class="card-body py-3">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <h6 class="fw-semibold mb-1">@challenge.Title</h6>
                                        <div class="text-muted small">
                                            @challenge.ProteinTargetGrams g protein/day &middot;
                                            Starts @challenge.StartDate.ToString("MMM d") &middot;
                                            @count participant@(count != 1 ? "s" : "")
                                        </div>
                                    </div>
                                    <div class="d-flex gap-2">
                                        <form asp-action="Join" asp-route-id="@challenge.Id" method="post" class="m-0">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-dark">Accept</button>
                                        </form>
                                        <form asp-action="Leave" asp-route-id="@challenge.Id" method="post" class="m-0">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-secondary">Decline</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Community tab -->
        <div class="tab-pane fade" id="tab-community">
            @if (!Model.CommunityChallenges.Any())
            {
                <div class="text-center py-5">
                    <p class="text-muted mb-3">No open community challenges.</p>
                    <a asp-action="Create" class="btn btn-dark btn-sm px-4">Create a community challenge</a>
                </div>
            }
            else
            {
                <div class="d-flex flex-column gap-3">
                    @foreach (var (challenge, count) in Model.CommunityChallenges)
                    {
                        var dayNum = Math.Min(7, (int)(DateTime.UtcNow - challenge.StartDate).TotalDays + 1);
                        <div class="card shadow-sm">
                            <div class="card-body py-3">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <h6 class="fw-semibold mb-1">@challenge.Title</h6>
                                        <div class="text-muted small">
                                            @challenge.ProteinTargetGrams g protein/day &middot;
                                            Day @dayNum of 7 &middot;
                                            @count participant@(count != 1 ? "s" : "")
                                        </div>
                                        @if (!string.IsNullOrEmpty(challenge.Description))
                                        {
                                            <p class="text-muted small mt-1 mb-0">@challenge.Description</p>
                                        }
                                    </div>
                                    <form asp-action="Join" asp-route-id="@challenge.Id" method="post" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-dark">Join</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Completed tab -->
        <div class="tab-pane fade" id="tab-completed">
            @if (!Model.CompletedChallenges.Any())
            {
                <p class="text-muted py-4 text-center">No completed challenges yet.</p>
            }
            else
            {
                <div class="d-flex flex-column gap-3">
                    @foreach (var (challenge, count) in Model.CompletedChallenges)
                    {
                        <a asp-action="Dashboard" asp-route-id="@challenge.Id" class="text-decoration-none">
                            <div class="card shadow-sm">
                                <div class="card-body py-3">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <h6 class="fw-semibold mb-1 text-dark">@challenge.Title</h6>
                                            <div class="text-muted small">
                                                @challenge.ProteinTargetGrams g protein/day &middot;
                                                @challenge.StartDate.ToString("MMM d") – @challenge.EndDate.ToString("MMM d") &middot;
                                                @count participant@(count != 1 ? "s" : "")
                                            </div>
                                        </div>
                                        <span class="badge bg-secondary">Completed</span>
                                    </div>
                                </div>
                            </div>
                        </a>
                    }
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        if (location.hash === '#invites') {
            document.querySelector('[data-bs-target="#tab-invites"]').click();
        }
    </script>
}
