@using dupi.Models
@model List<(dupi.Models.Friendship F, dupi.Models.UserProfile? Profile)>
@{
    ViewData["Title"] = "Friends";
    var requests = ViewBag.Requests as List<(dupi.Models.Friendship F, dupi.Models.UserProfile? Profile)> ?? new();
}

<div class="container mt-4" style="max-width:760px;">
    <h1 class="mb-4">Friends</h1>

    <ul class="nav nav-tabs mb-4" id="friendsTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-friends" type="button">
                Friends <span class="badge bg-secondary ms-1">@Model.Count</span>
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-requests" type="button">
                Requests
                @if (requests.Count > 0)
                {
                    <span class="badge bg-danger ms-1">@requests.Count</span>
                }
            </button>
        </li>
    </ul>

    <div class="tab-content">

        <!-- Friends tab -->
        <div class="tab-pane fade show active" id="tab-friends">
            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <p class="text-muted mb-3">You haven't added any friends yet.</p>
                    <a asp-controller="Discover" asp-action="Index" class="btn btn-dark btn-sm px-4">Discover people</a>
                </div>
            }
            else
            {
                <div class="d-flex flex-column gap-3">
                    @foreach (var (f, profile) in Model)
                    {
                        var friendId = f.SenderId == ViewContext.HttpContext.User.FindFirst("dupi:uid")?.Value ? f.ReceiverId : f.SenderId;
                        var name = profile?.DisplayName ?? "Unknown";
                        var username = profile?.Username;
                        <div class="card shadow-sm">
                            <div class="card-body d-flex align-items-center gap-3 py-3">
                                <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center fw-bold flex-shrink-0"
                                     style="width:44px; height:44px; font-size:1rem;">
                                    @name.FirstOrDefault().ToString().ToUpper()
                                </div>
                                <div class="flex-grow-1 overflow-hidden">
                                    @if (!string.IsNullOrEmpty(username))
                                    {
                                        <a href="/u/@username" class="fw-semibold text-dark text-decoration-none">@name</a>
                                        <div class="text-muted small">&#64;@username</div>
                                    }
                                    else
                                    {
                                        <span class="fw-semibold">@name</span>
                                    }
                                </div>
                                <div class="d-flex gap-2 flex-shrink-0">
                                    <a asp-controller="Chat" asp-action="Index" asp-route-friendId="@friendId"
                                       class="btn btn-sm btn-outline-primary">Message</a>
                                    <a asp-controller="Challenge" asp-action="Create" asp-route-friendId="@friendId"
                                       class="btn btn-sm btn-outline-success">Challenge</a>
                                    <form asp-controller="Friends" asp-action="Unfriend" method="post" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="otherId" value="@friendId" />
                                        <button type="submit" class="btn btn-sm btn-outline-secondary"
                                                onclick="return confirm('Remove @Html.Raw(name) as a friend?')">Unfriend</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Requests tab -->
        <div class="tab-pane fade" id="tab-requests">
            @if (!requests.Any())
            {
                <p class="text-muted py-4 text-center">No pending friend requests.</p>
            }
            else
            {
                <div class="d-flex flex-column gap-3">
                    @foreach (var (f, profile) in requests)
                    {
                        var name = profile?.DisplayName ?? "Unknown";
                        var username = profile?.Username;
                        <div class="card shadow-sm">
                            <div class="card-body d-flex align-items-center gap-3 py-3">
                                <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center fw-bold flex-shrink-0"
                                     style="width:44px; height:44px; font-size:1rem;">
                                    @name.FirstOrDefault().ToString().ToUpper()
                                </div>
                                <div class="flex-grow-1 overflow-hidden">
                                    @if (!string.IsNullOrEmpty(username))
                                    {
                                        <a href="/u/@username" class="fw-semibold text-dark text-decoration-none">@name</a>
                                        <div class="text-muted small">&#64;@username</div>
                                    }
                                    else
                                    {
                                        <span class="fw-semibold">@name</span>
                                    }
                                    <div class="text-muted small">sent you a friend request</div>
                                </div>
                                <div class="d-flex gap-2 flex-shrink-0">
                                    <form asp-controller="Friends" asp-action="Accept" method="post" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="senderId" value="@f.SenderId" />
                                        <button type="submit" class="btn btn-sm btn-dark">Accept</button>
                                    </form>
                                    <form asp-controller="Friends" asp-action="Decline" method="post" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="senderId" value="@f.SenderId" />
                                        <button type="submit" class="btn btn-sm btn-outline-secondary">Decline</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

    </div>
</div>

@section Scripts {
    <script>
        // If URL has #requests, switch to that tab
        if (location.hash === '#requests') {
            document.querySelector('[data-bs-target="#tab-requests"]').click();
        }
    </script>
}
