@model dupi.Models.UserProfile
@{
    ViewData["Title"] = "My Profile";

    var goalOptions = new[]
    {
        ("", "— Not specified —"),
        ("Lose weight", "Lose weight"),
        ("Build muscle", "Build muscle"),
        ("Maintain weight", "Maintain weight"),
        ("Improve nutrition quality", "Improve nutrition quality"),
        ("Increase energy levels", "Increase energy levels"),
        ("Athletic performance", "Athletic performance"),
        ("Reduce body fat", "Reduce body fat"),
        ("Eat healthier overall", "Eat healthier overall"),
    };

    var dietOptions = new[]
    {
        ("", "— No specific diet —"),
        ("Balanced", "Balanced"),
        ("Vegetarian", "Vegetarian"),
        ("Vegan", "Vegan"),
        ("Keto", "Keto"),
        ("Low-carb", "Low-carb"),
        ("Mediterranean", "Mediterranean"),
        ("Paleo", "Paleo"),
        ("Gluten-free", "Gluten-free"),
        ("Dairy-free", "Dairy-free"),
    };
}

<div class="container mt-4" style="max-width: 700px;">
    <h1 class="mb-4">My Profile</h1>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @* Daily Fun Fact Card *@
    @{
        var funFact = ViewBag.FunFact as dupi.Models.DailyFunFact;
    }
    @if (funFact != null)
    {
        <div class="card mb-4" style="background: linear-gradient(135deg, #f8f9ff 0%, #e8f4fd 100%); border-left: 4px solid #6c63ff;">
            <div class="card-header bg-transparent border-bottom-0 d-flex justify-content-between align-items-center">
                <span class="fw-semibold">✨ Today's Fun Fact</span>
                <span class="text-muted small">Refreshes daily</span>
            </div>
            <div class="card-body pt-0">
                @if (ViewBag.FunFactError != null)
                {
                    <div class="alert alert-warning py-1 px-2 mb-2 small">Debug: @ViewBag.FunFactError</div>
                }
                <div class="d-flex align-items-start gap-3">
                    <span style="font-size:2rem;line-height:1.2;">@funFact.Emoji</span>
                    <div>
                        <p class="mb-2 fw-medium">@funFact.Fact</p>
                        <div class="text-muted small"><span class="fw-semibold">Today's tip:</span> @funFact.Tip</div>
                    </div>
                </div>
            </div>
        </div>
    }

    <form asp-action="Save" asp-controller="Profile" method="post">
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Profile details</span>
                @if (Model.IsPublic && !string.IsNullOrEmpty(Model.Username))
                {
                    <a href="/u/@Model.Username" target="_blank" class="btn btn-sm btn-outline-success">View public page &rarr;</a>
                }
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Username</label>
                    <div class="input-group">
                        <span class="input-group-text text-muted">dupi.com/u/</span>
                        <input name="Username" value="@Model.Username" class="form-control"
                               placeholder="your-username" pattern="[a-zA-Z0-9_\-]{3,30}" />
                    </div>
                    <div class="form-text">3–30 characters. Letters, numbers, hyphens and underscores only.</div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Display name</label>
                    <input name="DisplayName" value="@Model.DisplayName" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Bio</label>
                    <textarea name="Bio" class="form-control" rows="3">@Model.Bio</textarea>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-sm-6">
                        <label class="form-label">My goal</label>
                        <select name="Goals" class="form-select">
                            @foreach (var (value, label) in goalOptions)
                            {
                                if (value == Model.Goals)
                                {
                                    <option value="@value" selected>@label</option>
                                }
                                else
                                {
                                    <option value="@value">@label</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label">Diet type</label>
                        <select name="DietType" class="form-select">
                            @foreach (var (value, label) in dietOptions)
                            {
                                if (value == Model.DietType)
                                {
                                    <option value="@value" selected>@label</option>
                                }
                                else
                                {
                                    <option value="@value">@label</option>
                                }
                            }
                        </select>
                    </div>
                </div>
                <div class="form-check form-switch mb-1">
                    <input class="form-check-input" type="checkbox" name="IsPublic" value="true"
                           id="isPublic" @(Model.IsPublic ? "checked" : "") />
                    <input type="hidden" name="IsPublic" value="false" />
                    <label class="form-check-label" for="isPublic">Make my profile public</label>
                </div>
                <small class="text-muted">When public, anyone can find you on the Discover page.</small>
            </div>
            <div class="card-footer text-end">
                <button type="submit" class="btn btn-primary">Save</button>
            </div>
        </div>
    </form>
</div>

