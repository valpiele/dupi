<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - dupi</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/dupi.styles.css" asp-append-version="true" />
    <style>
        /* ── Sidebar tokens ── */
        :root {
            --sb-w: 56px;
            --sb-w-exp: 220px;
            --sb-bg: #f9f8f6;
            --sb-border: #ebe8e2;
            --sb-hover: #f0ece6;
            --sb-active: #ece8e2;
            --sb-text: #64635f;
            --sb-text-active: #1a1a1a;
            --sb-radius: 8px;
            --sb-ease: 200ms ease;
        }

        /* ── Sidebar shell ── */
        .sidebar {
            position: fixed;
            left: 0; top: 0; bottom: 0;
            width: var(--sb-w);
            background: var(--sb-bg);
            border-right: 1px solid var(--sb-border);
            display: flex;
            flex-direction: column;
            transition: width var(--sb-ease);
            overflow: hidden;
            z-index: 1040;
        }
        .app-layout.expanded .sidebar { width: var(--sb-w-exp); }

        /* ── Header (brand + toggle) ── */
        .sidebar-header {
            display: flex;
            align-items: center;
            padding: 12px 8px;
            min-height: 56px;
            flex-shrink: 0;
        }
        .sidebar-brand {
            flex: 1 1 0%;
            min-width: 0;
            overflow: hidden;
            white-space: nowrap;
            padding: 0 10px;
            font-weight: 700;
            font-size: 1.15rem;
            color: var(--sb-text-active);
            text-decoration: none;
            letter-spacing: -0.5px;
        }
        .sidebar-brand:hover { color: var(--sb-text-active); }
        .sidebar-toggle {
            flex-shrink: 0;
            width: 40px;
            height: 40px;
            border: none;
            background: none;
            color: var(--sb-text);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: var(--sb-radius);
            padding: 0;
            transition: color 150ms, background 150ms;
        }
        .sidebar-toggle:hover { color: var(--sb-text-active); background: var(--sb-hover); }

        /* ── Nav links ── */
        .sidebar-nav {
            flex: 1;
            padding: 4px 8px;
            display: flex;
            flex-direction: column;
            gap: 2px;
            overflow-y: auto;
            overflow-x: hidden;
        }
        .sidebar-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px;
            color: var(--sb-text);
            text-decoration: none;
            border-radius: var(--sb-radius);
            white-space: nowrap;
            overflow: hidden;
            position: relative;
            transition: color 150ms, background 150ms;
            font-size: 0.9rem;
        }
        .sidebar-link:hover { color: var(--sb-text-active); background: var(--sb-hover); }
        .sidebar-link.active { color: var(--sb-text-active); background: var(--sb-active); font-weight: 500; }
        .sidebar-link .bi { font-size: 1.15rem; flex-shrink: 0; width: 20px; text-align: center; }

        /* ── Labels (hidden when collapsed) ── */
        .sidebar-label {
            overflow: hidden;
            opacity: 0;
            transition: opacity 150ms;
        }
        .app-layout.expanded .sidebar-label { opacity: 1; }

        /* ── Notification badges ── */
        .sidebar-badge {
            font-size: 0.65rem;
            min-width: 18px;
            height: 18px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 9px;
            background: #dc3545;
            color: #fff;
            font-weight: 600;
            padding: 0 5px;
            margin-left: auto;
            flex-shrink: 0;
        }
        .app-layout:not(.expanded) .sidebar-badge {
            position: absolute;
            top: 6px;
            right: 6px;
            min-width: 8px;
            width: 8px;
            height: 8px;
            font-size: 0;
            padding: 0;
            margin: 0;
        }

        /* ── Footer / user section ── */
        .sidebar-footer {
            padding: 8px;
            border-top: 1px solid var(--sb-border);
            flex-shrink: 0;
        }
        .sidebar-user-btn {
            display: flex;
            align-items: center;
            gap: 10px;
            width: 100%;
            padding: 8px 10px;
            border: none;
            background: none;
            border-radius: var(--sb-radius);
            cursor: pointer;
            overflow: hidden;
            white-space: nowrap;
            color: var(--sb-text-active);
            transition: background 150ms;
        }
        .sidebar-user-btn:hover { background: var(--sb-hover); }
        .sidebar-avatar {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            background: var(--sb-text-active);
            color: #fff;
            font-size: 0.78rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }
        .sidebar-username {
            font-size: 0.88rem;
            font-weight: 500;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .sidebar-chevron {
            margin-left: auto;
            font-size: 0.75rem;
            color: var(--sb-text);
        }
        .sidebar-footer .dropdown-menu {
            min-width: 200px;
            border: 1px solid #e5e5e5;
            box-shadow: 0 8px 24px rgba(0,0,0,.1);
            border-radius: 12px;
            padding: 8px;
        }
        .sidebar-footer .dropdown-item {
            border-radius: 8px;
            font-size: 0.88rem;
            padding: 8px 12px;
        }
        .sidebar-footer .dropdown-item:hover { background: #f5f5f5; }
        .sidebar-footer .dropdown-divider { margin: 6px 0; }
        .sidebar-user-email {
            font-size: 0.75rem;
            color: #888;
            padding: 4px 12px 6px;
            display: block;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            max-width: 200px;
        }

        /* ── Main content ── */
        .main-content {
            margin-left: var(--sb-w);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            transition: margin-left var(--sb-ease);
        }
        .app-layout.expanded .main-content { margin-left: var(--sb-w-exp); }
        .main-content > .container { flex: 1; }

        /* ── Mobile ── */
        .mobile-menu-btn {
            display: none;
            position: fixed;
            top: 10px;
            left: 10px;
            z-index: 1050;
            width: 40px;
            height: 40px;
            border: none;
            background: #fff;
            border-radius: 10px;
            box-shadow: 0 2px 8px rgba(0,0,0,.1);
            align-items: center;
            justify-content: center;
            font-size: 1.3rem;
            color: var(--sb-text-active);
            cursor: pointer;
        }
        .sidebar-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.25);
            z-index: 1035;
        }
        .sidebar-overlay.show { display: block; }

        @@media (max-width: 767.98px) {
            .mobile-menu-btn { display: flex; }
            .sidebar {
                width: var(--sb-w-exp);
                transform: translateX(-100%);
                transition: transform var(--sb-ease);
            }
            .app-layout.expanded .sidebar { width: var(--sb-w-exp); }
            .sidebar.mobile-open { transform: translateX(0); }
            .main-content,
            .app-layout.expanded .main-content { margin-left: 0 !important; padding-top: 56px; }
            .sidebar .sidebar-label { opacity: 1; }
            .sidebar .sidebar-badge {
                position: static !important;
                min-width: 18px !important;
                width: auto !important;
                height: 18px !important;
                font-size: 0.65rem !important;
                padding: 0 5px !important;
                margin-left: auto !important;
            }
        }
    </style>
</head>
<body>
    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString()?.ToLower();
    }

    <button class="mobile-menu-btn" id="mobileMenuBtn" aria-label="Open menu">
        <i class="bi bi-list"></i>
    </button>
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <div class="app-layout" id="appLayout">
        <aside class="sidebar" id="sidebar" aria-label="Sidebar">
            <div class="sidebar-header">
                <a class="sidebar-brand" asp-controller="Home" asp-action="Index">dupi</a>
                <button class="sidebar-toggle" id="sidebarToggle" title="Toggle sidebar" aria-label="Toggle sidebar">
                    <i class="bi bi-layout-sidebar-inset"></i>
                </button>
            </div>

            <nav class="sidebar-nav" aria-label="Main navigation">
                <a class="sidebar-link @(currentController == "discover" ? "active" : "")"
                   asp-controller="Discover" asp-action="Index" title="Discover">
                    <i class="bi bi-compass"></i>
                    <span class="sidebar-label">Discover</span>
                </a>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a class="sidebar-link @(currentController == "nutrition" ? "active" : "")"
                       asp-controller="Nutrition" asp-action="Index" title="Nutrition">
                        <i class="bi bi-heart-pulse"></i>
                        <span class="sidebar-label">Nutrition</span>
                    </a>
                    @await Component.InvokeAsync("SocialBadges", new { currentController })
                }
            </nav>

            <div class="sidebar-footer">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="d-flex align-items-center w-100 gap-1">
                        <a class="sidebar-user-btn flex-grow-1 text-decoration-none"
                           asp-controller="Profile" asp-action="Index">
                            <span class="sidebar-avatar">@User.Identity.Name![0].ToString().ToUpper()</span>
                            <span class="sidebar-label sidebar-username">@User.Identity.Name</span>
                        </a>
                        <div class="dropup">
                            <button class="btn btn-sm btn-link text-muted p-1 sidebar-label" type="button"
                                    data-bs-toggle="dropdown" aria-expanded="false" title="More options">
                                <i class="bi bi-three-dots-vertical"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <a class="dropdown-item" asp-controller="Profile" asp-action="Index">
                                        <i class="bi bi-gear me-2"></i>Settings
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="bi bi-box-arrow-right me-2"></i>Sign out
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    </div>
                }
                else
                {
                    <a class="sidebar-link" asp-controller="Account" asp-action="Login" title="Sign in">
                        <i class="bi bi-box-arrow-in-right"></i>
                        <span class="sidebar-label">Sign in</span>
                    </a>
                }
            </div>
        </aside>

        <div class="main-content">
            <div class="container">
                <main role="main" class="pb-3">
                    @RenderBody()
                </main>
            </div>
            <footer class="border-top footer text-muted">
                <div class="container">
                    &copy; 2026 - dupi - <a asp-controller="Home" asp-action="Privacy">Privacy</a>
                </div>
            </footer>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        (function () {
            var layout = document.getElementById('appLayout');
            var sidebar = document.getElementById('sidebar');
            var toggle = document.getElementById('sidebarToggle');
            var mobileBtn = document.getElementById('mobileMenuBtn');
            var overlay = document.getElementById('sidebarOverlay');
            var KEY = 'dupi-sidebar-expanded';

            function isMobile() { return window.innerWidth < 768; }

            function applyDesktop() {
                if (isMobile()) { layout.classList.remove('expanded'); return; }
                if (localStorage.getItem(KEY) === 'true') layout.classList.add('expanded');
                else layout.classList.remove('expanded');
            }

            toggle.addEventListener('click', function () {
                if (isMobile()) { closeMobile(); return; }
                var on = layout.classList.toggle('expanded');
                localStorage.setItem(KEY, on);
            });

            function openMobile() {
                sidebar.classList.add('mobile-open');
                overlay.classList.add('show');
                document.body.style.overflow = 'hidden';
            }
            function closeMobile() {
                sidebar.classList.remove('mobile-open');
                overlay.classList.remove('show');
                document.body.style.overflow = '';
            }

            mobileBtn.addEventListener('click', function () {
                sidebar.classList.contains('mobile-open') ? closeMobile() : openMobile();
            });
            overlay.addEventListener('click', closeMobile);

            sidebar.querySelectorAll('.sidebar-link').forEach(function (a) {
                a.addEventListener('click', function () { if (isMobile()) closeMobile(); });
            });

            window.addEventListener('resize', function () {
                if (!isMobile()) { closeMobile(); applyDesktop(); }
            });

            applyDesktop();
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
