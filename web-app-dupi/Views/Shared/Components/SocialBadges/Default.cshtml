@{
    int pending = ViewBag.Pending;
    int unread = ViewBag.Unread;
    int challengeInvites = ViewBag.ChallengeInvites;
    string ctrl = ViewBag.CurrentController ?? "";
}
<a class="sidebar-link @(ctrl == "friends" ? "active" : "")"
   asp-controller="Friends" asp-action="Index" title="Friends">
    <i class="bi bi-people"></i>
    <span class="sidebar-label">Friends</span>
    @if (pending > 0)
    {
        <span class="sidebar-badge">@pending</span>
    }
</a>
<a class="sidebar-link @(ctrl == "chat" ? "active" : "")"
   asp-controller="Chat" asp-action="Index" title="Chat">
    <i class="bi bi-chat-dots"></i>
    <span class="sidebar-label">Chat</span>
    @if (unread > 0)
    {
        <span class="sidebar-badge">@unread</span>
    }
</a>
<a class="sidebar-link @(ctrl == "challenge" ? "active" : "")"
   asp-controller="Challenge" asp-action="Index" title="Challenges">
    <i class="bi bi-trophy"></i>
    <span class="sidebar-label">Challenges</span>
    @if (challengeInvites > 0)
    {
        <span class="sidebar-badge">@challengeInvites</span>
    }
</a>
