@using dupi.Models
@{
    ViewData["Title"] = "Chat";
    var conversations  = ViewBag.Conversations as List<(string FriendId, UserProfile? Profile, Message Last, int Unread)> ?? new();
    var messages       = ViewBag.Messages as List<Message> ?? new();
    var activeFriendId = ViewBag.ActiveFriendId as string;
    var friendProfile  = ViewBag.FriendProfile as UserProfile;
    var myId           = User.FindFirst("dupi:uid")?.Value ?? "";
    var friends        = ViewBag.Friends as List<(Friendship F, UserProfile? Profile)> ?? new();
    var onlineFriendIds = ViewBag.OnlineFriendIds as HashSet<string> ?? new HashSet<string>();
    var challengeData  = ViewBag.ChallengeData as Dictionary<int, Challenge> ?? new();
    var friendInitial  = friendProfile != null ? friendProfile.DisplayName.FirstOrDefault().ToString().ToUpper() : "";
    var friendIsOnline = activeFriendId != null && onlineFriendIds.Contains(activeFriendId);

    // Build message clusters: consecutive same-sender messages within 5 min
    var clusters = new List<List<Message>>();
    foreach (var m in messages)
    {
        var last = clusters.Count > 0 ? clusters[clusters.Count - 1] : null;
        var lastMsg = last != null ? last[last.Count - 1] : null;
        if (lastMsg == null || lastMsg.SenderId != m.SenderId || (m.SentAt - lastMsg.SentAt).TotalMinutes >= 5)
            clusters.Add(new List<Message> { m });
        else
            last!.Add(m);
    }

    bool IsEmojiOnly(string s)
    {
        var quick = new[] { "👍", "❤️", "😂", "😮", "😢", "😡", "🎉", "🔥", "💯", "😍", "🙏", "👏", "🥔" };
        return quick.Contains(s.Trim());
    }

    bool IsChallengeMsg(string content, out int cid)
    {
        cid = 0;
        return content.StartsWith("challenge:") && int.TryParse(content["challenge:".Length..], out cid);
    }
}

<style>
    .chat-layout {
        display: flex;
        height: calc(100vh - 70px);
        border-radius: 12px;
        overflow: hidden;
        background: #fff;
        border: 1px solid #E4E6EB;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    }

    /* ── Sidebar ─────────────────────────────────────── */
    .chat-sidebar {
        width: 360px; flex-shrink: 0;
        display: flex; flex-direction: column;
        border-right: 1px solid #E4E6EB;
        background: #fff;
    }
    .sidebar-top {
        padding: 16px 16px 8px;
        display: flex; align-items: center; justify-content: space-between;
    }
    .sidebar-title { font-size: 1.4rem; font-weight: 700; color: #050505; }
    .new-chat-btn {
        width: 36px; height: 36px; border-radius: 50%;
        background: #F0F2F5; border: none;
        display: flex; align-items: center; justify-content: center;
        color: #050505; cursor: pointer; transition: background .15s; flex-shrink: 0;
    }
    .new-chat-btn:hover { background: #E4E6EB; }

    .sidebar-search-wrap { padding: 0 16px 8px; }
    .sidebar-search {
        width: 100%; background: #F0F2F5; border: none;
        border-radius: 20px; padding: 8px 16px;
        font-size: 0.9rem; outline: none; color: #050505;
    }
    .sidebar-search::placeholder { color: #65676B; }

    .convo-list { flex: 1; overflow-y: auto; padding: 0 8px 8px; }
    .convo-item {
        display: flex; align-items: center; gap: 12px;
        padding: 8px; border-radius: 8px; cursor: pointer;
        text-decoration: none; color: inherit;
        transition: background .1s; margin-bottom: 2px;
    }
    .convo-item:hover { background: #F2F2F2; color: inherit; text-decoration: none; }
    .convo-item.active { background: #E7F3FF; color: inherit; }

    .avatar-wrap { position: relative; flex-shrink: 0; }
    .convo-avatar {
        width: 56px; height: 56px; border-radius: 50%;
        background: #0084FF; color: #fff;
        font-weight: 700; font-size: 1.1rem;
        display: flex; align-items: center; justify-content: center;
    }
    .online-dot {
        width: 13px; height: 13px;
        background: #31A24C; border-radius: 50%;
        border: 2px solid #fff;
        position: absolute; bottom: 1px; right: 1px;
    }

    .convo-info { flex: 1; min-width: 0; }
    .convo-name {
        font-size: 0.92rem; font-weight: 400; color: #050505;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .convo-name.unread { font-weight: 700; }
    .convo-last {
        font-size: 0.8rem; color: #65676B;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .convo-last.unread { font-weight: 600; color: #050505; }
    .convo-meta { display: flex; flex-direction: column; align-items: flex-end; gap: 4px; flex-shrink: 0; }
    .convo-time { font-size: 0.72rem; color: #65676B; }
    .unread-dot { width: 10px; height: 10px; border-radius: 50%; background: #0084FF; }

    /* ── Main panel ──────────────────────────────────── */
    .chat-main { flex: 1; display: flex; flex-direction: column; min-width: 0; background: #fff; }

    .chat-header {
        padding: 12px 20px; border-bottom: 1px solid #E4E6EB;
        background: #fff; display: flex; align-items: center; gap: 12px;
    }
    .header-avatar-wrap { position: relative; flex-shrink: 0; }
    .header-avatar {
        width: 40px; height: 40px; border-radius: 50%;
        background: #0084FF; color: #fff;
        font-weight: 700; font-size: 0.9rem;
        display: flex; align-items: center; justify-content: center;
    }
    .header-online-dot {
        width: 12px; height: 12px;
        background: #31A24C; border-radius: 50%;
        border: 2px solid #fff;
        position: absolute; bottom: 0; right: 0;
    }
    .header-info { display: flex; flex-direction: column; }
    .header-name { font-size: 0.95rem; font-weight: 700; color: #050505; }
    .header-sub { font-size: 0.78rem; color: #31A24C; font-weight: 500; }

    /* ── Messages ────────────────────────────────────── */
    .msg-area {
        flex: 1; overflow-y: auto;
        padding: 16px 20px;
        display: flex; flex-direction: column; gap: 0;
        background: #fff;
    }

    .date-sep {
        align-self: center;
        font-size: 0.74rem; color: #65676B; font-weight: 500;
        padding: 6px 10px; margin: 6px 0;
    }

    .msg-cluster { display: flex; margin-top: 8px; }
    .msg-cluster:first-child { margin-top: 0; }
    .msg-cluster.out { flex-direction: column; align-items: flex-end; }
    .msg-cluster.in  { flex-direction: row; align-items: flex-end; gap: 8px; }

    .msg-avatar-small {
        width: 28px; height: 28px; border-radius: 50%;
        background: #0084FF; color: #fff;
        font-size: 0.65rem; font-weight: 700;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }
    .msg-avatar-placeholder { width: 28px; flex-shrink: 0; }

    .msg-bubbles { display: flex; flex-direction: column; gap: 2px; }
    .msg-cluster.in  .msg-bubbles { align-items: flex-start; }
    .msg-cluster.out .msg-bubbles { align-items: flex-end; }

    /* Bubble wrap — needed for hover actions */
    .bubble-wrap { position: relative; }

    .bubble {
        max-width: 420px; padding: 10px 14px;
        border-radius: 18px;
        font-size: 0.92rem; line-height: 1.45;
        word-break: break-word; display: inline-block;
    }
    .bubble-out { background: #0084FF; color: #fff; }
    .bubble-in  { background: #F0F2F5; color: #050505; }

    /* Border-radius per position in cluster */
    .bubble-in.bpos-single { border-bottom-left-radius: 4px; }
    .bubble-in.bpos-first  { border-bottom-left-radius: 4px; }
    .bubble-in.bpos-middle { border-top-left-radius: 4px; border-bottom-left-radius: 4px; }
    .bubble-in.bpos-last   { border-top-left-radius: 4px; }

    .bubble-out.bpos-single { border-bottom-right-radius: 4px; }
    .bubble-out.bpos-first  { border-bottom-right-radius: 4px; }
    .bubble-out.bpos-middle { border-top-right-radius: 4px; border-bottom-right-radius: 4px; }
    .bubble-out.bpos-last   { border-top-right-radius: 4px; }

    /* Large single emoji */
    .bubble.emoji-only {
        background: transparent !important;
        font-size: 2.4rem; padding: 2px 0; line-height: 1.2;
    }

    /* Hover action bar (reactions) */
    .bubble-actions {
        position: absolute;
        bottom: calc(100% + 4px);
        display: none;
        background: #fff;
        border: 1px solid #E4E6EB;
        border-radius: 20px;
        padding: 4px 6px;
        gap: 1px;
        align-items: center;
        box-shadow: 0 2px 12px rgba(0,0,0,.14);
        z-index: 20;
        white-space: nowrap;
    }
    .msg-cluster.out .bubble-wrap .bubble-actions { right: 0; }
    .msg-cluster.in  .bubble-wrap .bubble-actions { left: 0; }
    .bubble-wrap:hover .bubble-actions { display: flex; }

    .reaction-btn {
        background: none; border: none;
        padding: 2px 3px; font-size: 1.1rem;
        cursor: pointer; border-radius: 50%; line-height: 1;
        transition: transform .12s;
    }
    .reaction-btn:hover { transform: scale(1.35); }

    .bubble-time {
        font-size: 0.7rem; color: #65676B;
        margin-top: 2px; padding: 0 2px;
    }

    /* Typing indicator */
    .typing-bubble { padding: 12px 16px !important; }
    .typing-dot {
        display: inline-block;
        width: 8px; height: 8px; border-radius: 50%;
        background: #8A8D91; margin: 0 2px;
        animation: typingBounce 1.2s infinite;
    }
    .typing-dot:nth-child(2) { animation-delay: .2s; }
    .typing-dot:nth-child(3) { animation-delay: .4s; }
    @@keyframes typingBounce {
        0%, 60%, 100% { transform: translateY(0); }
        30%            { transform: translateY(-6px); }
    }

    /* Read receipt */
    .read-receipt-row {
        display: flex; justify-content: flex-end;
        padding-right: 2px; margin-top: 2px;
    }
    .read-receipt-avatar {
        width: 16px; height: 16px; border-radius: 50%;
        background: #0084FF; color: #fff;
        font-size: 0.48rem; font-weight: 700;
        display: flex; align-items: center; justify-content: center;
    }

    /* Load more */
    #loadMoreBtn {
        align-self: center; background: none; border: none;
        color: #0084FF; font-size: 0.82rem; font-weight: 600;
        padding: 4px 12px; cursor: pointer; margin-bottom: 8px;
    }
    #loadMoreBtn:hover { text-decoration: underline; }

    /* Input footer */
    .msg-footer {
        padding: 10px 16px; border-top: 1px solid #E4E6EB;
        background: #fff; display: flex; align-items: center; gap: 8px;
    }
    .msg-input-wrap {
        flex: 1; background: #F0F2F5; border-radius: 22px;
        display: flex; align-items: center; padding: 10px 16px;
    }
    .msg-input {
        flex: 1; background: transparent; border: none;
        outline: none; font-size: 0.93rem; color: #050505;
    }
    .msg-input::placeholder { color: #65676B; }
    .action-btn {
        background: none; border: none; padding: 0; cursor: pointer;
        color: #0084FF; display: flex; align-items: center; justify-content: center;
        width: 36px; height: 36px; border-radius: 50%;
        transition: background .12s; flex-shrink: 0;
    }
    .action-btn:hover { background: #F0F2F5; }
    .like-btn { font-size: 1.4rem; line-height: 1; }

    /* Empty state */
    .chat-empty {
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        height: 100%; gap: 10px; color: #65676B; text-align: center;
    }
    .chat-empty-icon {
        width: 80px; height: 80px; border-radius: 50%;
        background: #F0F2F5;
        display: flex; align-items: center; justify-content: center;
        margin-bottom: 4px;
    }

    /* ── Challenge card ─────────────────────────────────── */
    .challenge-card {
        max-width: 300px;
        background: #fff;
        border: 1.5px solid #E4E6EB;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0,0,0,.07);
        cursor: pointer;
        transition: box-shadow .15s;
        text-decoration: none;
        display: block;
    }
    .challenge-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,.12); text-decoration: none; }
    .cc-header {
        background: linear-gradient(135deg, #0084FF 0%, #0060CC 100%);
        padding: 12px 14px 10px;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .cc-trophy { font-size: 1.2rem; }
    .cc-tag { font-size: 0.72rem; font-weight: 700; color: rgba(255,255,255,.85); letter-spacing: .04em; text-transform: uppercase; }
    .cc-status {
        margin-left: auto;
        font-size: 0.67rem;
        font-weight: 700;
        padding: 2px 8px;
        border-radius: 20px;
        background: rgba(255,255,255,.2);
        color: #fff;
    }
    .cc-status.active  { background: rgba(49,162,76,.35); }
    .cc-status.pending { background: rgba(255,180,0,.35); }
    .cc-body { padding: 10px 14px 12px; }
    .cc-title {
        font-size: 0.93rem;
        font-weight: 700;
        color: #050505;
        margin-bottom: 5px;
        line-height: 1.3;
    }
    .cc-meta {
        font-size: 0.78rem;
        color: #65676B;
        display: flex;
        align-items: center;
        gap: 6px;
        flex-wrap: wrap;
    }
    .cc-pill {
        background: #F0F2F5;
        border-radius: 10px;
        padding: 2px 8px;
        font-size: 0.73rem;
        font-weight: 500;
        color: #050505;
    }
    .cc-footer {
        padding: 8px 14px;
        border-top: 1px solid #F0F2F5;
        font-size: 0.78rem;
        font-weight: 600;
        color: #0084FF;
    }

    /* ── Challenge picker popover ──────────────────────── */
    .challenge-picker {
        position: absolute;
        bottom: calc(100% + 8px);
        left: 0;
        width: 260px;
        background: #fff;
        border: 1px solid #E4E6EB;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0,0,0,.14);
        z-index: 50;
        overflow: hidden;
    }
    .cp-header {
        padding: 10px 14px 8px;
        font-size: 0.82rem;
        font-weight: 700;
        color: #65676B;
        border-bottom: 1px solid #F0F2F5;
    }
    .cp-list { max-height: 240px; overflow-y: auto; }
    .cp-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 9px 14px;
        cursor: pointer;
        transition: background .1s;
    }
    .cp-item:hover { background: #F0F2F5; }
    .cp-emoji { font-size: 1.3rem; flex-shrink: 0; }
    .cp-info { min-width: 0; }
    .cp-name { font-size: 0.87rem; font-weight: 600; color: #050505; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .cp-sub  { font-size: 0.74rem; color: #65676B; }
    .cp-empty { padding: 14px; font-size: 0.83rem; color: #65676B; text-align: center; }

    /* Wrapper for the + button — needed for picker positioning */
    .plus-btn-wrap { position: relative; flex-shrink: 0; }

    @@media (max-width: 640px) {
        .chat-sidebar { width: 72px; }
        .convo-info, .convo-meta, .sidebar-search-wrap, .sidebar-title { display: none; }
    }
</style>

<div class="chat-layout mt-2">
    <!-- Sidebar -->
    <div class="chat-sidebar">
        <div class="sidebar-top">
            <span class="sidebar-title">Chats</span>
            <button class="new-chat-btn" data-bs-toggle="modal" data-bs-target="#newChatModal" title="New chat">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M15.502 1.94a.5.5 0 0 1 0 .706L14.459 3.69l-2-2L13.502.646a.5.5 0 0 1 .707 0l1.293 1.293zm-1.75 2.456-2-2L4.939 9.21a.5.5 0 0 0-.121.196l-.805 2.414a.25.25 0 0 0 .316.316l2.414-.805a.5.5 0 0 0 .196-.12l6.813-6.814z"/>
                    <path fill-rule="evenodd" d="M1 13.5A1.5 1.5 0 0 0 2.5 15h11a1.5 1.5 0 0 0 1.5-1.5v-6a.5.5 0 0 0-1 0v6a.5.5 0 0 1-.5.5h-11a.5.5 0 0 1-.5-.5v-11a.5.5 0 0 1 .5-.5H9a.5.5 0 0 0 0-1H2.5A1.5 1.5 0 0 0 1 2.5z"/>
                </svg>
            </button>
        </div>

        <div class="sidebar-search-wrap">
            <input class="sidebar-search" type="text" placeholder="Search Chats" oninput="filterConvos(this.value)" />
        </div>

        <div class="convo-list">
            @if (!conversations.Any())
            {
                <div class="text-center text-muted small mt-4 px-3">
                    No conversations yet.<br />
                    <a asp-controller="Friends" asp-action="Index" class="text-primary">Find friends</a>
                </div>
            }
            @foreach (var (fid, prof, last, unread) in conversations)
            {
                var name = prof?.DisplayName ?? "User";
                var isActive = fid == activeFriendId;
                var lastTime = last.SentAt.Date == DateTime.UtcNow.Date
                    ? last.SentAt.ToString("HH:mm")
                    : last.SentAt.ToString("dd MMM");
                var isOnline = onlineFriendIds.Contains(fid);
                <a href="/Chat?friendId=@fid" class="convo-item @(isActive ? "active" : "") convo-entry" data-name="@name.ToLower()" data-friend-id="@fid">
                    <div class="avatar-wrap">
                        <div class="convo-avatar">@name.FirstOrDefault().ToString().ToUpper()</div>
                        @if (isOnline) { <div class="online-dot"></div> }
                    </div>
                    <div class="convo-info">
                        <div class="convo-name @(unread > 0 ? "unread" : "")">@name</div>
                        <div class="convo-last @(unread > 0 ? "unread" : "")">@last.Content</div>
                    </div>
                    <div class="convo-meta">
                        <span class="convo-time">@lastTime</span>
                        @if (unread > 0) { <div class="unread-dot"></div> }
                    </div>
                </a>
            }
        </div>
    </div>

    <!-- Main panel -->
    <div class="chat-main">
        @if (activeFriendId == null || friendProfile == null)
        {
            <div class="chat-empty">
                <div class="chat-empty-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="38" height="38" fill="#0084FF" viewBox="0 0 16 16">
                        <path d="M8 15c4.418 0 8-3.134 8-7s-3.582-7-8-7-8 3.134-8 7c0 1.76.743 3.37 1.97 4.6-.097 1.016-.417 2.13-.771 2.966-.079.186.074.394.273.362 2.256-.37 3.597-.938 4.18-1.234A9.06 9.06 0 0 0 8 15z"/>
                    </svg>
                </div>
                <span style="font-size:1.05rem;font-weight:700;color:#050505;">Your messages</span>
                <span style="font-size:0.87rem;">Send a message to start a chat.</span>
                <button class="btn btn-primary btn-sm rounded-pill px-4 mt-1" style="background:#0084FF;border-color:#0084FF;"
                        data-bs-toggle="modal" data-bs-target="#newChatModal">
                    New message
                </button>
            </div>
        }
        else
        {
            <!-- Header -->
            <div class="chat-header">
                <div class="header-avatar-wrap">
                    <div class="header-avatar">@friendInitial</div>
                    <div class="header-online-dot @(friendIsOnline ? "" : "d-none")" id="friendOnlineDot"></div>
                </div>
                <div class="header-info">
                    <span class="header-name">@friendProfile.DisplayName</span>
                    <span class="header-sub" id="friendStatus">@(friendIsOnline ? "Active now" : "")</span>
                </div>
            </div>

            <!-- Messages -->
            <div class="msg-area" id="msgArea">
                <button id="loadMoreBtn" class="d-none" onclick="loadMore()">Load earlier messages</button>

                <div id="messages">
                    @{
                        DateTime? prevClusterDate = null;
                    }
                    @for (int ci = 0; ci < clusters.Count; ci++)
                    {
                        var cluster = clusters[ci];
                        var clusterDate = cluster[0].SentAt;
                        var isOut = cluster[0].SenderId == myId;

                        // Date separator
                        if (prevClusterDate == null || clusterDate.Date != prevClusterDate.Value.Date)
                        {
                            var label = clusterDate.Date == DateTime.UtcNow.Date ? "Today"
                                      : clusterDate.Date == DateTime.UtcNow.Date.AddDays(-1) ? "Yesterday"
                                      : clusterDate.ToString("ddd, MMM d");
                            <div class="date-sep">@label</div>
                        }
                        prevClusterDate = clusterDate;

                        <div class="msg-cluster @(isOut ? "out" : "in")" data-last-sent-at="@cluster[cluster.Count - 1].SentAt.ToString("o")">
                            @if (!isOut)
                            {
                                <div class="msg-avatar-small">@friendInitial</div>
                            }
                            <div class="msg-bubbles">
                                @for (int bi = 0; bi < cluster.Count; bi++)
                                {
                                    var m = cluster[bi];
                                    var pos = cluster.Count == 1 ? "single"
                                            : bi == 0 ? "first"
                                            : bi == cluster.Count - 1 ? "last"
                                            : "middle";
                                    @if (IsChallengeMsg(m.Content, out var challengeId) && challengeData.TryGetValue(challengeId, out var ch))
                                    {
                                        var (mName, mUnit, mEmoji) = ChallengeMetricHelper.GetInfo(ch.Metric);
                                        var dirLabel = ch.Direction == GoalDirection.AtLeast ? "at least" : "at most";
                                        var statusLbl = ch.Status.ToString().ToLower();
                                        <div class="bubble-wrap">
                                            <a href="/Challenge/Dashboard/@ch.Id" class="challenge-card" target="_blank">
                                                <div class="cc-header">
                                                    <span class="cc-trophy">🏆</span>
                                                    <span class="cc-tag">Challenge</span>
                                                    <span class="cc-status @statusLbl">@ch.Status</span>
                                                </div>
                                                <div class="cc-body">
                                                    <div class="cc-title">@ch.Title</div>
                                                    <div class="cc-meta">
                                                        <span>@mEmoji</span>
                                                        <span class="cc-pill">@mName @dirLabel @ch.TargetValue@mUnit</span>
                                                        <span class="cc-pill">Ends @ch.EndDate.ToString("MMM d")</span>
                                                    </div>
                                                </div>
                                                <div class="cc-footer">View Challenge →</div>
                                            </a>
                                        </div>
                                    }
                                    else
                                    {
                                        var emojiCls = IsEmojiOnly(m.Content) ? " emoji-only" : "";
                                        <div class="bubble-wrap">
                                            <div class="bubble @(isOut ? "bubble-out" : "bubble-in") bpos-@pos@emojiCls">@m.Content</div>
                                            <div class="bubble-actions">
                                                <button class="reaction-btn" onclick="sendReaction('👍')">👍</button>
                                                <button class="reaction-btn" onclick="sendReaction('❤️')">❤️</button>
                                                <button class="reaction-btn" onclick="sendReaction('😂')">😂</button>
                                                <button class="reaction-btn" onclick="sendReaction('😮')">😮</button>
                                                <button class="reaction-btn" onclick="sendReaction('😢')">😢</button>
                                                <button class="reaction-btn" onclick="sendReaction('😡')">😡</button>
                                            </div>
                                        </div>
                                    }
                                }
                                <div class="bubble-time">@cluster[cluster.Count - 1].SentAt.ToString("HH:mm")</div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Typing indicator -->
                <div id="typingIndicator" class="msg-cluster in d-none" style="margin-top:8px;">
                    <div class="msg-avatar-small">@friendInitial</div>
                    <div class="msg-bubbles">
                        <div class="bubble bubble-in bpos-single typing-bubble">
                            <span class="typing-dot"></span>
                            <span class="typing-dot"></span>
                            <span class="typing-dot"></span>
                        </div>
                    </div>
                </div>

                <!-- Read receipt -->
                <div id="readReceiptRow" class="read-receipt-row d-none">
                    <div class="read-receipt-avatar">@friendInitial</div>
                </div>
            </div>

            <!-- Input -->
            <div class="msg-footer">
                <div class="plus-btn-wrap">
                    <button id="plusBtn" class="action-btn" type="button" onclick="toggleChallengePicker(event)" title="Share challenge">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#0084FF" stroke-width="2.2" stroke-linecap="round">
                            <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/>
                        </svg>
                    </button>
                    <div id="challengePicker" class="challenge-picker d-none">
                        <div class="cp-header">Share a Challenge</div>
                        <div class="cp-list" id="cpList">
                            <div class="cp-empty">Loading...</div>
                        </div>
                    </div>
                </div>
                <div class="msg-input-wrap">
                    <input type="text" id="msgInput" class="msg-input"
                           placeholder="Aa" autocomplete="off" maxlength="2000"
                           oninput="onInputChange()" onkeydown="onKeyDown(event)" />
                </div>
                <button id="sendBtn" class="action-btn d-none" type="button" onclick="sendMessage()" title="Send">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="#0084FF" xmlns="http://www.w3.org/2000/svg">
                        <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
                    </svg>
                </button>
                <button id="likeBtn" class="action-btn like-btn" type="button" onclick="sendLike()" title="Like">🥔</button>
            </div>
        }
    </div>
</div>

<!-- New Chat Modal -->
<div class="modal fade" id="newChatModal" tabindex="-1" aria-labelledby="newChatModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-scrollable">
        <div class="modal-content" style="border-radius:12px;">
            <div class="modal-header border-0 pb-0">
                <h6 class="modal-title fw-bold" id="newChatModalLabel">New message</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0">
                <div class="px-3 pb-2 border-bottom">
                    <input type="text" id="friendSearch"
                           class="form-control border-0 ps-0 shadow-none"
                           placeholder="Search..." oninput="filterFriends()"
                           style="font-size:0.9rem;" />
                </div>
                <div id="friendList">
                    @if (!friends.Any())
                    {
                        <div class="p-3 text-muted small text-center">
                            No friends yet. <a asp-controller="Friends" asp-action="Index" class="text-primary">Add friends</a>
                        </div>
                    }
                    @foreach (var (f, prof) in friends)
                    {
                        var fid = f.SenderId == myId ? f.ReceiverId : f.SenderId;
                        var name = prof?.DisplayName ?? "User";
                        <a href="/Chat?friendId=@fid" class="convo-item friend-item" data-name="@name.ToLower()" style="border-radius:0;margin:0;">
                            <div class="avatar-wrap">
                                <div class="convo-avatar" style="width:44px;height:44px;font-size:0.9rem;">@name.FirstOrDefault().ToString().ToUpper()</div>
                            </div>
                            <div class="convo-info">
                                <div class="convo-name">@name</div>
                                @if (prof != null && !string.IsNullOrEmpty(prof.Username))
                                {
                                    <div class="convo-last">@@@prof.Username</div>
                                }
                            </div>
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.0/dist/browser/signalr.min.js"></script>
    <script>
        const myId           = '@myId';
        const activeFriendId = '@activeFriendId';
        const friendInitial  = '@friendInitial';
        let skipCount = @messages.Count;
        const pageSize = 60;

        const REACTIONS = ['👍', '❤️', '😂', '😮', '😢', '😡'];
        const EMOJI_QUICK = new Set(['👍', '❤️', '😂', '😮', '😢', '😡', '🎉', '🔥', '💯', '😍', '🙏', '👏']);

        // ── SignalR ──────────────────────────────────────────
        const connection = new signalR.HubConnectionBuilder()
            .withUrl('/chatHub')
            .withAutomaticReconnect()
            .build();

        connection.on('ReceiveMessage', msg => {
            if (msg.senderId !== activeFriendId && msg.senderId !== myId) return;
            appendMessage(msg.senderId === myId, msg.content, new Date(msg.sentAt));
            if (msg.senderId === activeFriendId) {
                connection.invoke('MarkRead', activeFriendId).catch(() => {});
                hideTyping();
            }
            if (msg.senderId === myId) {
                // Hide read receipt until friend reads the new message
                document.getElementById('readReceiptRow')?.classList.add('d-none');
            }
        });

        connection.on('MessagesRead', senderId => {
            if (senderId !== activeFriendId) return;
            document.getElementById('readReceiptRow')?.classList.remove('d-none');
        });

        connection.on('TypingStarted', userId => {
            if (userId !== activeFriendId) return;
            document.getElementById('typingIndicator')?.classList.remove('d-none');
            scrollToBottom();
        });

        connection.on('TypingStopped', userId => {
            if (userId !== activeFriendId) return;
            hideTyping();
        });

        connection.on('UserOnline', userId => {
            if (userId === activeFriendId) {
                document.getElementById('friendOnlineDot')?.classList.remove('d-none');
                const s = document.getElementById('friendStatus');
                if (s) s.textContent = 'Active now';
            }
            updateSidebarDot(userId, true);
        });

        connection.on('UserOffline', userId => {
            if (userId === activeFriendId) {
                document.getElementById('friendOnlineDot')?.classList.add('d-none');
                const s = document.getElementById('friendStatus');
                if (s) s.textContent = '';
            }
            updateSidebarDot(userId, false);
        });

        connection.start().then(() => {
            if (activeFriendId) connection.invoke('MarkRead', activeFriendId).catch(() => {});
            scrollToBottom();
            if (skipCount >= pageSize) document.getElementById('loadMoreBtn')?.classList.remove('d-none');
        }).catch(console.error);

        // ── Input handling ───────────────────────────────────
        let typingTimer = null;

        function onInputChange() {
            const hasText = document.getElementById('msgInput').value.trim().length > 0;
            document.getElementById('sendBtn').classList.toggle('d-none', !hasText);
            document.getElementById('likeBtn').classList.toggle('d-none', hasText);

            if (!activeFriendId) return;
            if (hasText) {
                if (!typingTimer) connection.invoke('StartTyping', activeFriendId).catch(() => {});
                clearTimeout(typingTimer);
                typingTimer = setTimeout(stopTyping, 2500);
            } else {
                stopTyping();
            }
        }

        function stopTyping() {
            if (typingTimer) { clearTimeout(typingTimer); typingTimer = null; }
            if (activeFriendId) connection.invoke('StopTyping', activeFriendId).catch(() => {});
        }

        function onKeyDown(e) {
            if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
        }

        function sendMessage() {
            const input = document.getElementById('msgInput');
            const text = input.value.trim();
            if (!text || !activeFriendId) return;
            stopTyping();
            input.value = '';
            onInputChange();
            connection.invoke('SendMessage', activeFriendId, text).catch(console.error);
        }

        function sendLike() {
            if (!activeFriendId) return;
            connection.invoke('SendMessage', activeFriendId, '🥔').catch(console.error);
        }

        function sendReaction(emoji) {
            if (!activeFriendId) return;
            connection.invoke('SendMessage', activeFriendId, emoji).catch(console.error);
        }

        // ── Challenge picker ─────────────────────────────────
        let pickerLoaded = false;

        function toggleChallengePicker(e) {
            e.stopPropagation();
            const picker = document.getElementById('challengePicker');
            const isHidden = picker.classList.contains('d-none');
            picker.classList.toggle('d-none', !isHidden);
            if (isHidden && !pickerLoaded) loadChallengePicker();
        }

        async function loadChallengePicker() {
            pickerLoaded = true;
            const list = document.getElementById('cpList');
            try {
                const res = await fetch('/Chat/ShareableChallenges');
                const challenges = await res.json();
                if (!challenges.length) {
                    list.innerHTML = '<div class="cp-empty">No active challenges.<br><a href="/Challenge" style="color:#0084FF;">Start one →</a></div>';
                    return;
                }
                list.innerHTML = challenges.map(c => `
                    <div class="cp-item" onclick="shareChallenge(${c.id})">
                        <div class="cp-emoji">${c.emoji}</div>
                        <div class="cp-info">
                            <div class="cp-name">${escHtml(c.title)}</div>
                            <div class="cp-sub">${c.metric} · ${c.status}</div>
                        </div>
                    </div>`).join('');
            } catch {
                list.innerHTML = '<div class="cp-empty">Failed to load.</div>';
            }
        }

        function shareChallenge(id) {
            if (!activeFriendId) return;
            document.getElementById('challengePicker').classList.add('d-none');
            connection.invoke('SendMessage', activeFriendId, `challenge:${id}`).catch(console.error);
        }

        // Close picker when clicking outside
        document.addEventListener('click', () => {
            document.getElementById('challengePicker')?.classList.add('d-none');
        });

        // ── DOM helpers ──────────────────────────────────────
        function makeActionsHtml() {
            return '<div class="bubble-actions">' +
                REACTIONS.map(e => `<button class="reaction-btn" onclick="sendReaction('${e}')">${e}</button>`).join('') +
                '</div>';
        }

        function isEmojiOnly(str) { return EMOJI_QUICK.has(str.trim()); }

        function isChallengeMsg(content) {
            return content.startsWith('challenge:') && !isNaN(parseInt(content.slice(10)));
        }

        function makeChallengeCard(c) {
            const statusCls = c.status === 'active' ? 'active' : 'pending';
            return `<a href="${c.url}" class="challenge-card" target="_blank">
                <div class="cc-header">
                    <span class="cc-trophy">🏆</span>
                    <span class="cc-tag">Challenge</span>
                    <span class="cc-status ${statusCls}">${c.status.charAt(0).toUpperCase() + c.status.slice(1)}</span>
                </div>
                <div class="cc-body">
                    <div class="cc-title">${escHtml(c.title)}</div>
                    <div class="cc-meta">
                        <span>${c.emoji}</span>
                        <span class="cc-pill">${c.metric} ${c.direction} ${c.target}${c.unit}</span>
                        <span class="cc-pill">Ends ${c.endDate}</span>
                    </div>
                </div>
                <div class="cc-footer">View Challenge →</div>
            </a>`;
        }

        async function appendChallengeMessage(isOut, content, date) {
            const id = parseInt(content.slice(10));
            const area = document.getElementById('messages');

            // Create cluster immediately with a loading placeholder
            const div = document.createElement('div');
            div.className = `msg-cluster ${isOut ? 'out' : 'in'}`;
            div.dataset.lastSentAt = date.toISOString();
            div.dataset.isChallenge = '1';

            if (!isOut) {
                const av = document.createElement('div');
                av.className = 'msg-avatar-small';
                av.textContent = friendInitial;
                div.appendChild(av);
            }

            const bubblesDiv = document.createElement('div');
            bubblesDiv.className = 'msg-bubbles';
            const wrap = document.createElement('div');
            wrap.className = 'bubble-wrap';
            wrap.innerHTML = '<div class="bubble bubble-in bpos-single" style="color:#65676B;font-size:.85rem;">Loading challenge...</div>';
            const timeEl = document.createElement('div');
            timeEl.className = 'bubble-time';
            timeEl.textContent = formatTime(date);
            bubblesDiv.appendChild(wrap);
            bubblesDiv.appendChild(timeEl);
            div.appendChild(bubblesDiv);
            area.appendChild(div);
            scrollToBottom();

            try {
                const res = await fetch(`/Chat/ChallengePreview/${id}`);
                if (res.ok) {
                    const c = await res.json();
                    wrap.innerHTML = makeChallengeCard(c);
                } else {
                    wrap.innerHTML = '<div class="bubble bubble-in bpos-single">Challenge not found.</div>';
                }
            } catch {
                wrap.innerHTML = '<div class="bubble bubble-in bpos-single">Could not load challenge.</div>';
            }
            scrollToBottom();
        }

        function appendMessage(isOut, content, date) {
            if (isChallengeMsg(content)) {
                appendChallengeMessage(isOut, content, date);
                return;
            }
            const area = document.getElementById('messages');
            const lastCluster = area.querySelector('.msg-cluster:last-child');
            const lastIsOut   = lastCluster ? lastCluster.classList.contains('out') : null;
            const lastDateStr = lastCluster?.dataset.lastSentAt;
            const lastDate    = lastDateStr ? new Date(lastDateStr) : null;
            const canGroup    = lastCluster !== null
                             && lastIsOut === isOut
                             && lastDate !== null
                             && (date - lastDate) < 5 * 60 * 1000;

            const emojiCls = isEmojiOnly(content) ? ' emoji-only' : '';
            const bClass   = `bubble ${isOut ? 'bubble-out' : 'bubble-in'}${emojiCls}`;

            if (canGroup) {
                const bubblesDiv = lastCluster.querySelector('.msg-bubbles');
                const wraps      = bubblesDiv.querySelectorAll('.bubble-wrap');
                const timeDiv    = bubblesDiv.querySelector('.bubble-time');

                // Demote the current last bubble
                if (wraps.length > 0) {
                    const b = wraps[wraps.length - 1].querySelector('.bubble');
                    if (b.classList.contains('bpos-single')) {
                        b.classList.replace('bpos-single', 'bpos-first');
                    } else if (b.classList.contains('bpos-last')) {
                        b.classList.replace('bpos-last', 'bpos-middle');
                    }
                }

                // New bubble is the last
                const wrap = document.createElement('div');
                wrap.className = 'bubble-wrap';
                wrap.innerHTML = `<div class="${bClass} bpos-last">${escHtml(content)}</div>${makeActionsHtml()}`;
                bubblesDiv.insertBefore(wrap, timeDiv);
                if (timeDiv) timeDiv.textContent = formatTime(date);
                lastCluster.dataset.lastSentAt = date.toISOString();
            } else {
                const div = document.createElement('div');
                div.className = `msg-cluster ${isOut ? 'out' : 'in'}`;
                div.dataset.lastSentAt = date.toISOString();

                if (!isOut) {
                    const av = document.createElement('div');
                    av.className = 'msg-avatar-small';
                    av.textContent = friendInitial;
                    div.appendChild(av);
                }

                const bubblesDiv = document.createElement('div');
                bubblesDiv.className = 'msg-bubbles';

                const wrap = document.createElement('div');
                wrap.className = 'bubble-wrap';
                wrap.innerHTML = `<div class="${bClass} bpos-single">${escHtml(content)}</div>${makeActionsHtml()}`;

                const timeEl = document.createElement('div');
                timeEl.className = 'bubble-time';
                timeEl.textContent = formatTime(date);

                bubblesDiv.appendChild(wrap);
                bubblesDiv.appendChild(timeEl);
                div.appendChild(bubblesDiv);
                area.appendChild(div);
            }

            scrollToBottom();
        }

        async function loadMore() {
            const btn = document.getElementById('loadMoreBtn');
            btn.disabled = true;
            const res  = await fetch(`/Chat/History?friendId=${activeFriendId}&skip=${skipCount}`);
            const msgs = await res.json();
            if (msgs.length < pageSize) btn.remove();
            else { btn.disabled = false; skipCount += msgs.length; }
            if (!msgs.length) return;

            // Build clusters from historical messages (chronological order from server)
            const hist = [];
            msgs.forEach(m => {
                const last    = hist.length > 0 ? hist[hist.length - 1] : null;
                const lastMsg = last ? last[last.length - 1] : null;
                const d       = new Date(m.sentAt);
                const ld      = lastMsg ? new Date(lastMsg.sentAt) : null;
                if (!last || lastMsg.senderId !== m.senderId || (d - ld) >= 5 * 60 * 1000)
                    hist.push([m]);
                else
                    last.push(m);
            });

            const area     = document.getElementById('messages');
            const firstEl  = area.querySelector('.msg-cluster');
            const fragment = document.createDocumentFragment();

            hist.forEach(cluster => {
                const isOut = cluster[0].senderId === myId;
                const div   = document.createElement('div');
                div.className = `msg-cluster ${isOut ? 'out' : 'in'}`;
                div.dataset.lastSentAt = new Date(cluster[cluster.length - 1].sentAt).toISOString();

                if (!isOut) {
                    const av = document.createElement('div');
                    av.className = 'msg-avatar-small';
                    av.textContent = friendInitial;
                    div.appendChild(av);
                }

                const bubblesDiv = document.createElement('div');
                bubblesDiv.className = 'msg-bubbles';

                cluster.forEach((m, i) => {
                    const pos = cluster.length === 1 ? 'single'
                              : i === 0 ? 'first'
                              : i === cluster.length - 1 ? 'last'
                              : 'middle';
                    const wrap = document.createElement('div');
                    wrap.className = 'bubble-wrap';
                    if (isChallengeMsg(m.content)) {
                        const cid = parseInt(m.content.slice(10));
                        wrap.innerHTML = '<div style="color:#65676B;font-size:.85rem;">Loading challenge...</div>';
                        fetch(`/Chat/ChallengePreview/${cid}`)
                            .then(r => r.ok ? r.json() : null)
                            .then(c => { if (c) wrap.innerHTML = makeChallengeCard(c); });
                    } else {
                        const emojiCls = isEmojiOnly(m.content) ? ' emoji-only' : '';
                        wrap.innerHTML = `<div class="bubble ${isOut ? 'bubble-out' : 'bubble-in'}${emojiCls} bpos-${pos}">${escHtml(m.content)}</div>${makeActionsHtml()}`;
                    }
                    bubblesDiv.appendChild(wrap);
                });

                const timeEl = document.createElement('div');
                timeEl.className = 'bubble-time';
                timeEl.textContent = formatTime(new Date(cluster[cluster.length - 1].sentAt));
                bubblesDiv.appendChild(timeEl);

                div.appendChild(bubblesDiv);
                fragment.appendChild(div);
            });

            area.insertBefore(fragment, firstEl);
        }

        function hideTyping() {
            document.getElementById('typingIndicator')?.classList.add('d-none');
        }

        function updateSidebarDot(userId, isOnline) {
            const item = document.querySelector(`.convo-entry[data-friend-id="${userId}"]`);
            if (!item) return;
            const wrap = item.querySelector('.avatar-wrap');
            if (!wrap) return;
            let dot = wrap.querySelector('.online-dot');
            if (isOnline && !dot) {
                dot = document.createElement('div');
                dot.className = 'online-dot';
                wrap.appendChild(dot);
            } else if (!isOnline && dot) {
                dot.remove();
            }
        }

        function scrollToBottom() {
            const a = document.getElementById('msgArea');
            if (a) a.scrollTop = a.scrollHeight;
        }

        function escHtml(str) {
            return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
        }

        function formatTime(d) {
            return d.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
        }

        function filterFriends() {
            const q = document.getElementById('friendSearch').value.toLowerCase();
            document.querySelectorAll('.friend-item').forEach(el => {
                el.style.display = el.dataset.name.includes(q) ? '' : 'none';
            });
        }

        function filterConvos(q) {
            q = q.toLowerCase();
            document.querySelectorAll('.convo-entry').forEach(el => {
                el.style.display = el.dataset.name.includes(q) ? '' : 'none';
            });
        }
    </script>
}
